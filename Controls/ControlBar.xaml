<UserControl
    x:Class="Draft.Controls.ControlBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Draft.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Border
        Padding="8"
        HorizontalAlignment="Center"
        Background="{StaticResource Brush.Island}"
        BorderBrush="{StaticResource Brush.Outline}"
        BorderThickness="1"
        CornerRadius="8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <!--  Logo Button  -->
            <StackPanel Orientation="Horizontal">
                <Button Content="Draft" Style="{StaticResource LogoButton}" />

                <!--  Divider  -->
                <Border
                    Grid.Column="2"
                    Width="1"
                    Margin="8,0"
                    Background="#1F2020" />

            </StackPanel>



            <!--  Workspace Mode Buttons  -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <RadioButton
                    Content="Editor"
                    GroupName="WorkspaceMode"
                    IsChecked="{Binding IsEditorState, Mode=TwoWay}"
                    Style="{StaticResource ControlRadioButton}" />
                <RadioButton
                    Margin="8,0"
                    Content="Split"
                    GroupName="WorkspaceMode"
                    IsChecked="{Binding IsSplitState, Mode=TwoWay}"
                    Style="{StaticResource ControlRadioButton}" />
                <RadioButton
                    Content="Preview"
                    GroupName="WorkspaceMode"
                    IsChecked="{Binding IsPreviewState, Mode=TwoWay}"
                    Style="{StaticResource ControlRadioButton}" />
            </StackPanel>


            <!--  Action Buttons  -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <!--  Divider  -->
                <Border
                    Grid.Column="2"
                    Width="1"
                    Margin="8,0"
                    Background="#1F2020" />

                <Button Style="{StaticResource ControlButton}">
                    <Path
                        Width="16"
                        Height="16"
                        Data="{StaticResource Icon.Folder}"
                        Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Stretch="Uniform" />
                </Button>
                <Button Margin="8,0" Style="{StaticResource ControlButton}">
                    <Path
                        Width="16"
                        Height="16"
                        Data="{StaticResource Icon.Save}"
                        Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Stretch="Uniform" />
                </Button>
                <Button Style="{StaticResource ControlButton}">
                    <Path
                        Width="16"
                        Height="16"
                        Data="{StaticResource Icon.Settings}"
                        Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Stretch="Uniform" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
