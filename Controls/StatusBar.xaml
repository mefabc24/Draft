<UserControl
    x:Class="Draft.Controls.StatusBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Draft.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="14"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>

        <!--  Left  -->
        <StackPanel Grid.Column="0" Orientation="Horizontal">
            <StackPanel
                Height="14"
                Orientation="Horizontal"
                Margin="0,0,24,0">
                <Image
                    Width="14"
                    Height="14"
                    Margin="0,0,8,0"
                    Source="/Assets/Icons/TestIconHighRes.png" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="/Assets/Fonts/#Manrope"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="#79A986"
                    Text="MARKDOWN" />
            </StackPanel>

            <StackPanel Height="14" Orientation="Horizontal">
                <Image
                    Width="14"
                    Height="14"
                    Margin="0,0,8,0"
                    Source="/Assets/Icons/TestIconHighRes.png" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="/Assets/Fonts/#Manrope"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="#ACABAA"
                    Text="1240 WORDS" />
            </StackPanel>
        </StackPanel>

        <!--  Spacer  -->

        <!--  Right  -->
        <StackPanel Grid.Column="2" Orientation="Horizontal">
            <StackPanel Height="14" Orientation="Horizontal">
                <Image
                    Width="14"
                    Height="14"
                    Margin="0,0,8,0"
                    Source="/Assets/Icons/TestIconHighRes.png" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="/Assets/Fonts/#Manrope"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="#ACABAA"
                    Text="SYNC ACTIVE" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
