<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="WindowControlButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Width" Value="60" />
        <Setter Property="Foreground" Value="{StaticResource Brush.WindowControlIcon}" />
        <Setter Property="Tag" Value="Default" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}">
                        <ContentPresenter />
                    </Border>

                    <ControlTemplate.Triggers>
                        <!--  Close Hover  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="Tag" Value="Close" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="border" Property="CornerRadius" Value="0,8,0,0" />
                            <Setter Property="Background" Value="{StaticResource Brush.CloseButtonBackground}" />
                        </MultiTrigger>

                        <!--  Default Hover  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="Tag" Value="Default" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="{StaticResource Brush.ButtonHover}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>