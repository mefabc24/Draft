<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--  Accent Colors  -->
    <SolidColorBrush x:Key="Brush.PrimaryAccent" Color="#A5C8FF" />
    <SolidColorBrush x:Key="Brush.SecondaryAccent" Color="#79A986" />

    <!--  Background Colors  -->
    <SolidColorBrush x:Key="Brush.WindowBG" Color="#0D0D0D" />
    <SolidColorBrush x:Key="Brush.Island" Color="#131313" />
    <SolidColorBrush x:Key="Brush.EditorHighlight" Color="#1A1A1A" />
    <SolidColorBrush x:Key="Brush.Outline" Color="#1A1A1A" />

    <!--  Text Colors  -->
    <SolidColorBrush x:Key="Brush.PrimaryText" Color="#ABABAB" />
    <SolidColorBrush x:Key="Brush.MutedText" Color="#504F4F" />
    <SolidColorBrush x:Key="Brush.EditorText" Color="#D9D9D9" />

    <!--  Functional Colors  -->
    <SolidColorBrush x:Key="Brush.Success" Color="#22C55E" />
    <SolidColorBrush x:Key="Brush.Warning" Color="#F59E0B" />
    <SolidColorBrush x:Key="Brush.Critical" Color="#EF4444" />
    <SolidColorBrush x:Key="Brush.Info" Color="#60A5FA" />
</ResourceDictionary>