<UserControl
    x:Class="Draft.Settings.Views.Pages.MenuCustomizationSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Draft.Settings.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    AllowDrop="True"
    d:DesignHeight="2000"
    d:DesignWidth="540"
    PreviewDragOver="View_PreviewDragOver"
    mc:Ignorable="d">
    <UserControl.Resources>
        <DataTemplate x:Key="MenuCustomizationItemTemplate">
            <controls:MenuCustomizationSettingCard Margin="0,0,0,12" />
        </DataTemplate>
    </UserControl.Resources>

    <Border Background="Transparent">
        <ScrollViewer
            x:Name="SettingsScrollViewer"
            HorizontalScrollBarVisibility="Disabled"
            Style="{StaticResource SettingsScrollViewer}"
            VerticalScrollBarVisibility="Auto">
            <StackPanel VerticalAlignment="Top">
                <controls:SectionHeader Title="{Binding VisibleSectionTitle}" />
                <ItemsControl
                    MinHeight="12"
                    AllowDrop="True"
                    Background="Transparent"
                    DragOver="Section_DragOver"
                    Drop="Section_Drop"
                    ItemTemplate="{StaticResource MenuCustomizationItemTemplate}"
                    ItemsSource="{Binding VisibleItems}"
                    Tag="Visible" />

                <Border Height="20" />
                <controls:SectionHeader Title="{Binding OverflowSectionTitle}" />
                <ItemsControl
                    MinHeight="12"
                    AllowDrop="True"
                    Background="Transparent"
                    DragOver="Section_DragOver"
                    Drop="Section_Drop"
                    ItemTemplate="{StaticResource MenuCustomizationItemTemplate}"
                    ItemsSource="{Binding OverflowItems}"
                    Tag="Overflow" />

                <Border Height="20" />
                <controls:SectionHeader Title="{Binding DisabledSectionTitle}" />
                <ItemsControl
                    MinHeight="12"
                    AllowDrop="True"
                    Background="Transparent"
                    DragOver="Section_DragOver"
                    Drop="Section_Drop"
                    ItemTemplate="{StaticResource MenuCustomizationItemTemplate}"
                    ItemsSource="{Binding DisabledItems}"
                    Tag="Disabled" />
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
