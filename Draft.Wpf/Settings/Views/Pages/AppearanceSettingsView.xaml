<UserControl
    x:Class="Draft.Settings.Views.Pages.AppearanceSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i18n="clr-namespace:Draft.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:section="clr-namespace:Draft.Settings.Controls"
    xmlns:settings="clr-namespace:Draft.Settings.Controls"
    d:DesignHeight="2000"
    d:DesignWidth="540"
    mc:Ignorable="d">
    <Border Background="Transparent">
        <ScrollViewer
            HorizontalScrollBarVisibility="Disabled"
            Style="{StaticResource SettingsScrollViewer}"
            VerticalScrollBarVisibility="Auto">
            <StackPanel VerticalAlignment="Top">
                <section:SectionHeader Title="{i18n:Loc settings.appearance.themeSection}" />

                <settings:SettingCard
                    Title="{i18n:Loc settings.appearance.appTheme}"
                    Margin="0,0,0,32"
                    Description="{i18n:Loc settings.appearance.appTheme.description}">
                    <ComboBox
                        Width="160"
                        Height="36"
                        IsEnabled="False"
                        ItemTemplate="{StaticResource LocalizedComboBoxItemTemplate}"
                        ItemsSource="{Binding AppThemeOptions}"
                        SelectedItem="{Binding Settings.AppTheme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource SettingsComboBox}" />
                </settings:SettingCard>

                <section:SectionHeader Title="{i18n:Loc settings.appearance.layoutSection}" />

                <settings:SettingCard
                    Title="{i18n:Loc settings.appearance.toolbarPosition}"
                    Margin="0,0,0,32"
                    Description="{i18n:Loc settings.appearance.toolbarPosition.description}">
                    <ComboBox
                        Width="160"
                        Height="36"
                        IsEnabled="False"
                        ItemTemplate="{StaticResource LocalizedComboBoxItemTemplate}"
                        ItemsSource="{Binding ToolbarControlbarPositionOptions}"
                        SelectedItem="{Binding Settings.ToolbarControlbarPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource SettingsComboBox}" />
                </settings:SettingCard>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
