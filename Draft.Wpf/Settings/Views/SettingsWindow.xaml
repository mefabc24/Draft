<Window
    x:Class="Draft.Settings.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Draft.Settings.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settings="clr-namespace:Draft.Settings.Views.Pages"
    xmlns:settingsVm="clr-namespace:Draft.Settings.ViewModels.Pages"
    Title="{Binding SettingsTitle, FallbackValue=Settings}"
    Width="900"
    Height="600"
    AllowsTransparency="True"
    Background="Transparent"
    Icon="/Assets/Icons/draft.ico"
    WindowStyle="None"
    mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <DataTemplate DataType="{x:Type settingsVm:GeneralSettingsPageViewModel}">
                <settings:GeneralSettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type settingsVm:EditorSettingsPageViewModel}">
                <settings:EditorSettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type settingsVm:PreviewSettingsPageViewModel}">
                <settings:PreviewSettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type settingsVm:FloatingMarkdownToolbarSettingsPageViewModel}">
                <settings:MenuCustomizationSettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type settingsVm:QuickInsertSettingsPageViewModel}">
                <settings:MenuCustomizationSettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type settingsVm:AppearanceSettingsPageViewModel}">
                <settings:AppearanceSettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type settingsVm:StatusBarSettingsPageViewModel}">
                <settings:StatusBarSettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type settingsVm:ShortcutsSettingsPageViewModel}">
                <settings:ShortcutsSettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type settingsVm:DevelopSettingsPageViewModel}">
                <settings:DevelopSettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type settingsVm:AboutSettingsPageViewModel}">
                <settings:AboutSettingsView />
            </DataTemplate>

            <Style x:Key="SettingsPageTitleTransition" TargetType="TextBlock">
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TranslateTransform X="0" />
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <EventTrigger RoutedEvent="Binding.TargetUpdated">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="Opacity"
                                    From="0"
                                    To="1"
                                    Duration="0:0:0.14">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                    From="8"
                                    To="0"
                                    Duration="0:0:0.18">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="SettingsPageContentTransition" TargetType="ContentControl">
                <Setter Property="ClipToBounds" Value="True" />
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TranslateTransform X="0" />
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <EventTrigger RoutedEvent="Binding.TargetUpdated">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="Opacity"
                                    From="0"
                                    To="1"
                                    Duration="0:0:0.16">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                    From="14"
                                    To="0"
                                    Duration="0:0:0.22">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="SettingsSearchResultItem" TargetType="ListBoxItem">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border
                                x:Name="ResultBackground"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ResultBackground" Property="Background" Value="{StaticResource Brush.Background.Hover}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="ResultBackground" Property="Background" Value="{StaticResource Brush.Background.InputHover}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="48"
            GlassFrameThickness="0"
            ResizeBorderThickness="6" />
    </WindowChrome.WindowChrome>

    <Border x:Name="SettingsWindowFrameBorder" Background="{StaticResource Brush.Island}">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.SettingsWindow.Active}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.SettingsWindow.Inactive}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding AppliedWindowBorderAccentMode}" Value="Always">
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.PrimaryAccent}" />
                    </DataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding AppliedWindowBorderAccentMode}" Value="FocusedWindowOnly" />
                            <Condition Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.PrimaryAccent}" />
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding AppliedWindowBorderAccentMode}" Value="UnfocusedWindowsOnly" />
                            <Condition Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.PrimaryAccent}" />
                    </MultiDataTrigger>
                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="CornerRadius" Value="0" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Side Menu -->
            <Border Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                FontFamily="{StaticResource Font.Manrope}"
                                FontSize="20"
                                FontWeight="Bold"
                                Foreground="{StaticResource Brush.PrimaryAccent}"
                                Text="{Binding SettingsTitle, FallbackValue=Settings}" />
                            <Button
                                Grid.Column="1"
                                Padding="24,0"
                                VerticalAlignment="Stretch"
                                Command="{Binding ResetToDefaultsCommand}"
                                Style="{StaticResource RestoreSettingsButton}"
                                ToolTip="{Binding SettingsResetDefaultsTooltip, FallbackValue='Restore Default Settings'}"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                                <Path
                                    Width="12"
                                    Height="12"
                                    Data="{StaticResource Icon.Undo}"
                                    Fill="{StaticResource Brush.Text.Secondary}"
                                    Stretch="Uniform" />
                            </Button>
                        </Grid>

                        <TextBlock
                            FontFamily="{StaticResource Font.Inter}"
                            FontSize="11"
                            FontWeight="Regular"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{Binding SettingsConfigurationLabel, FallbackValue=Configuration}" />

                        <Border
                            x:Name="GlobalSettingsSearchBorder"
                            Height="38"
                            Margin="0,20,0,0"
                            Background="{StaticResource Brush.Background.Window}"
                            BorderBrush="{StaticResource Brush.Background.Secondary}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Path
                                    Width="15"
                                    Height="15"
                                    Margin="11,0,0,0"
                                    VerticalAlignment="Center"
                                    Data="{StaticResource Icon.Search}"
                                    Fill="{StaticResource Brush.Text.Placeholder}"
                                    IsHitTestVisible="False"
                                    Stretch="Uniform" />

                                <TextBox
                                    x:Name="GlobalSettingsSearchTextBox"
                                    Grid.Column="1"
                                    Margin="9,0,10,0"
                                    AutomationProperties.Name="{Binding SettingsSearchPlaceholder}"
                                    GotKeyboardFocus="GlobalSettingsSearchTextBox_GotKeyboardFocus"
                                    PreviewKeyDown="GlobalSettingsSearchTextBox_PreviewKeyDown"
                                    Style="{StaticResource SettingsSearchTextBox}"
                                    Tag="{Binding SettingsSearchPlaceholder}"
                                    Text="{Binding SettingsSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    TextChanged="GlobalSettingsSearchTextBox_TextChanged"
                                    WindowChrome.IsHitTestVisibleInChrome="True" />
                            </Grid>
                        </Border>

                        <Popup
                            x:Name="GlobalSettingsSearchPopup"
                            AllowsTransparency="True"
                            Focusable="False"
                            IsOpen="{Binding DataContext.IsSettingsSearchPopupOpen, ElementName=GlobalSettingsSearchBorder, Mode=TwoWay}"
                            Placement="Bottom"
                            PlacementTarget="{Binding ElementName=GlobalSettingsSearchBorder}"
                            PopupAnimation="Fade"
                            StaysOpen="False"
                            VerticalOffset="4">
                            <Border
                                Width="{Binding ActualWidth, ElementName=GlobalSettingsSearchBorder}"
                                MaxHeight="300"
                                Background="{StaticResource SettingsComboBoxPopupBackground}"
                                BorderBrush="{StaticResource Brush.Background.Secondary}"
                                BorderThickness="1"
                                CornerRadius="4"
                                DataContext="{Binding DataContext, ElementName=GlobalSettingsSearchBorder}">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="24"
                                        Color="{StaticResource Color.Shadow.Default}"
                                        Opacity="0.32"
                                        ShadowDepth="8" />
                                </Border.Effect>

                                <ListBox
                                    x:Name="GlobalSettingsSearchResultsList"
                                    Padding="2"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    ItemContainerStyle="{StaticResource SettingsSearchResultItem}"
                                    ItemsSource="{Binding SettingsSearchResults}"
                                    MouseLeftButtonUp="GlobalSettingsSearchResultsList_MouseLeftButtonUp"
                                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                    ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.Template>
                                        <ControlTemplate TargetType="ListBox">
                                            <ScrollViewer
                                                CanContentScroll="False"
                                                Style="{StaticResource SettingsCompactScrollViewer}">
                                                <ItemsPresenter />
                                            </ScrollViewer>
                                        </ControlTemplate>
                                    </ListBox.Template>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock
                                                    FontFamily="{StaticResource Font.Inter}"
                                                    FontSize="13"
                                                    FontWeight="Medium"
                                                    Foreground="{StaticResource Brush.Text.Primary}"
                                                    Text="{Binding Title}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Margin="0,2,0,0"
                                                    FontFamily="{StaticResource Font.Inter}"
                                                    FontSize="11"
                                                    Foreground="{StaticResource Brush.Text.Secondary}"
                                                    Text="{Binding PageTitle}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Popup>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,32">
                        <RadioButton
                            Height="36"
                            Margin="0,0,0,4"
                            GroupName="SettingsMenu"
                            IsChecked="{Binding IsGeneralSettingsSelected, Mode=TwoWay}"
                            Style="{StaticResource SettingsMenuRadioButton}">
                            <StackPanel Orientation="Horizontal">
                                <Path
                                    Width="16"
                                    Height="16"
                                    Data="{StaticResource Icon.Settings}"
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                    Stretch="Uniform" />
                                <TextBlock Margin="12,0,0,0" Text="{Binding GeneralSettingsMenuLabel, FallbackValue=General}" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton
                            Height="36"
                            Margin="0,0,0,4"
                            GroupName="SettingsMenu"
                            IsChecked="{Binding IsEditorSettingsSelected, Mode=TwoWay}"
                            Style="{StaticResource SettingsMenuRadioButton}">
                            <StackPanel Orientation="Horizontal">
                                <Path
                                    Width="16"
                                    Height="16"
                                    Data="{StaticResource Icon.Editor}"
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                    Stretch="Uniform" />
                                <TextBlock Margin="12,0,0,0" Text="{Binding EditorSettingsMenuLabel, FallbackValue=Editor}" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton
                            Height="36"
                            Margin="0,0,0,4"
                            GroupName="SettingsMenu"
                            IsChecked="{Binding IsPreviewSettingsSelected, Mode=TwoWay}"
                            Style="{StaticResource SettingsMenuRadioButton}">
                            <StackPanel Orientation="Horizontal">
                                <Path
                                    Width="16"
                                    Height="16"
                                    Data="{StaticResource Icon.Preview}"
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                    Stretch="Uniform" />
                                <TextBlock Margin="12,0,0,0" Text="{Binding PreviewSettingsMenuLabel, FallbackValue=Preview}" />
                            </StackPanel>
                        </RadioButton>

                        <Expander
                            IsExpanded="{Binding IsCustomizationsExpanded, Mode=TwoWay}"
                            Style="{StaticResource SettingsMenuExpander}">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Path
                                        Width="16"
                                        Height="16"
                                        Data="{StaticResource Icon.Customizations}"
                                        Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                        Stretch="Uniform" />
                                    <TextBlock Margin="12,0,0,0" Text="{Binding CustomizationsSettingsMenuLabel, FallbackValue=Customizations}" />
                                </StackPanel>
                            </Expander.Header>

                            <StackPanel>
                                <RadioButton
                                    Height="36"
                                    Margin="0,0,0,4"
                                    GroupName="SettingsMenu"
                                    IsChecked="{Binding IsFloatingMarkdownToolbarSettingsSelected, Mode=TwoWay}"
                                    Style="{StaticResource SettingsSubmenuRadioButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path
                                            Width="16"
                                            Height="16"
                                            Data="{StaticResource Icon.FloatingMarkdownToolbar}"
                                            Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                            Stretch="Uniform" />
                                        <TextBlock Margin="12,0,0,0" Text="{Binding FloatingMarkdownToolbarSettingsMenuLabel, FallbackValue='Markdown Toolbar'}" />
                                    </StackPanel>
                                </RadioButton>

                                <RadioButton
                                    Height="36"
                                    GroupName="SettingsMenu"
                                    IsChecked="{Binding IsQuickInsertSettingsSelected, Mode=TwoWay}"
                                    Style="{StaticResource SettingsSubmenuRadioButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path
                                            Width="16"
                                            Height="16"
                                            Data="{StaticResource Icon.QuickInsertMenu}"
                                            Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                            Stretch="Uniform" />
                                        <TextBlock Margin="12,0,0,0" Text="{Binding QuickInsertSettingsMenuLabel, FallbackValue='Insert Menu'}" />
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>
                        </Expander>

                        <RadioButton
                            Height="36"
                            Margin="0,0,0,4"
                            GroupName="SettingsMenu"
                            IsChecked="{Binding IsAppearanceSettingsSelected, Mode=TwoWay}"
                            Style="{StaticResource SettingsMenuRadioButton}">
                            <StackPanel Orientation="Horizontal">
                                <Path
                                    Width="16"
                                    Height="16"
                                    Data="{StaticResource Icon.Appearance}"
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                    Stretch="Uniform" />
                                <TextBlock Margin="12,0,0,0" Text="{Binding AppearanceSettingsMenuLabel, FallbackValue=Appearance}" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton
                            Height="36"
                            Margin="0,0,0,4"
                            GroupName="SettingsMenu"
                            IsChecked="{Binding IsStatusBarSettingsSelected, Mode=TwoWay}"
                            Style="{StaticResource SettingsMenuRadioButton}">
                            <StackPanel Orientation="Horizontal">
                                <Path
                                    Width="16"
                                    Height="16"
                                    Data="{StaticResource Icon.File}"
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                    Stretch="Uniform" />
                                <TextBlock Margin="12,0,0,0" Text="{Binding StatusBarSettingsMenuLabel, FallbackValue='Status Bar'}" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton
                            Height="36"
                            Margin="0,0,0,4"
                            GroupName="SettingsMenu"
                            IsChecked="{Binding IsShortcutsSettingsSelected, Mode=TwoWay}"
                            Style="{StaticResource SettingsMenuRadioButton}">
                            <StackPanel Orientation="Horizontal">
                                <Path
                                    Width="16"
                                    Height="16"
                                    Data="{StaticResource Icon.Shortcuts}"
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                    Stretch="Uniform" />
                                <TextBlock Margin="12,0,0,0" Text="{Binding ShortcutsSettingsMenuLabel, FallbackValue=Shortcuts}" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton
                            Height="36"
                            Margin="0,0,0,4"
                            GroupName="SettingsMenu"
                            IsChecked="{Binding IsDevelopSettingsSelected, Mode=TwoWay}">
                            <RadioButton.Style>
                                <Style BasedOn="{StaticResource SettingsMenuRadioButton}" TargetType="RadioButton">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDevelopSettingsVisible}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </RadioButton.Style>
                            <StackPanel Orientation="Horizontal">
                                <Path
                                    Width="16"
                                    Height="16"
                                    Data="{StaticResource Icon.Terminal}"
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                    Stretch="Uniform" />
                                <TextBlock Margin="12,0,0,0" Text="{Binding DevelopSettingsMenuLabel, FallbackValue=Develop}" />
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>

                    <RadioButton
                        Grid.Row="2"
                        Height="36"
                        GroupName="SettingsMenu"
                        IsChecked="{Binding IsAboutSettingsSelected, Mode=TwoWay}"
                        Style="{StaticResource SettingsMenuRadioButton}">
                        <StackPanel Orientation="Horizontal">
                            <Path
                                Width="16"
                                Height="16"
                                Data="{StaticResource Icon.About}"
                                Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                Stretch="Uniform" />
                            <TextBlock Margin="12,0,0,0" Text="{Binding AboutSettingsMenuLabel, FallbackValue=About}" />
                        </StackPanel>
                    </RadioButton>
                </Grid>
            </Border>

            <!-- Divider -->
            <Border Grid.Column="1" Background="{StaticResource Brush.Border.Default}" />


            <!-- Content -->
            <Border Grid.Column="2" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            FontFamily="{StaticResource Font.Manrope}"
                            FontSize="32"
                            FontWeight="Bold"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Style="{StaticResource SettingsPageTitleTransition}"
                            Text="{Binding CurrentSettingsPage.Title, FallbackValue='Page Title', NotifyOnTargetUpdated=True}" />

                        <!-- Close Button -->
                        <Button
                            Grid.Column="1"
                            VerticalAlignment="Top"
                            Click="CloseButton_Click"
                            Style="{StaticResource DraftCloseButton}"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                            <Path
                                Width="12"
                                Height="12"
                                Data="{StaticResource Icon.Close}"
                                Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                Stretch="Uniform" />
                        </Button>
                    </Grid>

                    <AdornerDecorator Grid.Row="1" Margin="0,16">
                        <ContentControl
                            x:Name="SettingsPageContent"
                            Content="{Binding CurrentSettingsPage, NotifyOnTargetUpdated=True}"
                            Style="{StaticResource SettingsPageContentTransition}" />
                    </AdornerDecorator>

                    <Grid Grid.Row="2">
                        <TextBlock
                            MaxWidth="250"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Font.Inter}"
                            FontSize="11"
                            Foreground="{StaticResource Brush.Function.Critical}"
                            Text="{Binding ShortcutConflictSummary}"
                            TextWrapping="Wrap"
                            Visibility="{Binding HasShortcutConflicts, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <StackPanel
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                            <Button
                                Width="160"
                                Margin="0,0,16,0"
                                Padding="24,0"
                                VerticalAlignment="Stretch"
                                Command="{Binding CancelSettingsCommand}"
                                Content="{Binding CancelButtonText, FallbackValue=Cancel}"
                                Style="{StaticResource MessageDialogSecondaryButton}" />
                            <Button
                                Width="160"
                                Padding="24,0"
                                VerticalAlignment="Stretch"
                                Command="{Binding ApplySettingsCommand}"
                                Content="{Binding ApplyChangesButtonText, FallbackValue='Apply Changes'}"
                                Style="{StaticResource MessageDialogPrimaryButton}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
