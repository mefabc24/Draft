<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Draft.Settings.Controls">

    <SolidColorBrush
        x:Key="ShortcutRecorderActiveBackground"
        Color="#202020" />

    <SolidColorBrush
        x:Key="ShortcutRecorderButtonHoverBackground"
        Opacity="0.08"
        Color="{StaticResource Color.Text.Secondary}" />

    <SolidColorBrush
        x:Key="ShortcutRecorderActiveButtonHoverBackground"
        Opacity="0.16"
        Color="{StaticResource Color.Function.Critical}" />

    <Style x:Key="ShortcutRecorderControl" TargetType="{x:Type controls:ShortcutRecorder}">
        <Setter Property="Focusable" Value="True" />
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ShortcutRecorderBorder" TargetType="{x:Type Border}">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="12,0,4,0" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Background" Value="{StaticResource Brush.Background.Input}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Input}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Effect" Value="{x:Null}" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsRecording, RelativeSource={RelativeSource AncestorType={x:Type controls:ShortcutRecorder}}}" Value="True">
                <Setter Property="Background" Value="{StaticResource ShortcutRecorderActiveBackground}" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.Function.Critical}" />
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect
                            BlurRadius="14"
                            Opacity="0.8"
                            ShadowDepth="0"
                            Color="{StaticResource Color.Function.Critical}" />
                    </Setter.Value>
                </Setter>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ShortcutRecorderText" TargetType="{x:Type TextBlock}">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{StaticResource Font.SpaceGrotesk}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsRecording, RelativeSource={RelativeSource AncestorType={x:Type controls:ShortcutRecorder}}}" Value="True">
                <Setter Property="Foreground" Value="{StaticResource Brush.Function.Critical}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ShortcutButton" TargetType="{x:Type Button}">
        <Setter Property="Width" Value="26" />
        <Setter Property="Height" Value="26" />
        <Setter Property="Margin" Value="0,0,1,0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
        <Setter Property="ToolTip" Value="Record shortcut" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border
                        x:Name="ButtonBorder"
                        Background="{TemplateBinding Background}"
                        CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource ShortcutRecorderButtonHoverBackground}" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Foreground" Value="{StaticResource Brush.Icon.SubtleHover}" />
            </Trigger>

            <DataTrigger Binding="{Binding IsRecording, RelativeSource={RelativeSource AncestorType={x:Type controls:ShortcutRecorder}}}" Value="True">
                <Setter Property="Foreground" Value="{StaticResource Brush.Function.Critical}" />
                <Setter Property="ToolTip" Value="Recording shortcut. Click to stop." />
            </DataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                    <Condition Binding="{Binding IsRecording, RelativeSource={RelativeSource AncestorType={x:Type controls:ShortcutRecorder}}}" Value="True" />
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="{StaticResource ShortcutRecorderActiveButtonHoverBackground}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.Function.Critical}" />
            </MultiDataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ShortcutRecorderIcon" TargetType="{x:Type Path}">
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Data" Value="{StaticResource Icon.Record}" />
        <Setter Property="Stretch" Value="Uniform" />
    </Style>

    <Style x:Key="ShortcutRestoreIcon" TargetType="{x:Type Path}">
        <Setter Property="Width" Value="14" />
        <Setter Property="Height" Value="14" />
        <Setter Property="Data" Value="{StaticResource Icon.Undo}" />
        <Setter Property="Stretch" Value="Uniform" />
    </Style>
</ResourceDictionary>
