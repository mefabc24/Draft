<UserControl
    x:Class="Draft.Settings.Controls.BetaBadge"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i18n="clr-namespace:Draft.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="42"
    Height="18"
    d:DesignHeight="18"
    d:DesignWidth="42"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    mc:Ignorable="d">
    <Border
        Background="{StaticResource Brush.Accent.Primary}"
        CornerRadius="3">
        <Grid>
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="{StaticResource Font.Inter}"
                FontSize="9"
                FontWeight="Bold"
                Foreground="{StaticResource Brush.Text.OnBadge}"
                Text="{i18n:Loc common.beta}"
                TextAlignment="Center"
                TextOptions.TextFormattingMode="Display">
                <TextBlock.RenderTransform>
                    <TranslateTransform Y="0.5" />
                </TextBlock.RenderTransform>
            </TextBlock>
        </Grid>
    </Border>
</UserControl>
