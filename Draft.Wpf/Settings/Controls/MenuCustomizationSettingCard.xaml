<UserControl
    x:Class="Draft.Settings.Controls.MenuCustomizationSettingCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i18n="clr-namespace:Draft.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="60"
    d:DesignWidth="500"
    mc:Ignorable="d">
    <Grid x:Name="CardRoot" HorizontalAlignment="Stretch">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="ReorderTransform" />
        </Grid.RenderTransform>

        <Border
            x:Name="CardBorder"
            Padding="0,12"
            HorizontalAlignment="Stretch"
            Background="Transparent"
            BorderThickness="1">
            <Grid HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="DragHandle"
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    AutomationProperties.Name="{i18n:Loc settings.menuCustomization.dragHandle, Fallback='Drag to reorder (Alt+Up/Down)'}"
                    GiveFeedback="DragHandle_GiveFeedback"
                    PreviewKeyDown="DragHandle_PreviewKeyDown"
                    PreviewMouseLeftButtonDown="DragHandle_PreviewMouseLeftButtonDown"
                    PreviewMouseLeftButtonUp="DragHandle_PreviewMouseLeftButtonUp"
                    PreviewMouseMove="DragHandle_PreviewMouseMove"
                    Style="{StaticResource SettingsDragHandleButton}"
                    ToolTip="{i18n:Loc settings.menuCustomization.dragHandle, Fallback='Drag to reorder (Alt+Up/Down)'}">
                    <Path
                        Width="18"
                        Height="18"
                        Data="{StaticResource Icon.Drag}"
                        Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Stretch="Uniform" />
                </Button>

                <TextBlock
                    Grid.Column="1"
                    Margin="0,0,24,0"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Font.Inter}"
                    FontSize="16"
                    FontWeight="Regular"
                    Foreground="{StaticResource Brush.Text.Primary}"
                    Text="{Binding Title}"
                    TextWrapping="Wrap" />

                <ComboBox
                    Grid.Column="2"
                    Width="200"
                    Height="36"
                    ItemTemplate="{StaticResource LocalizedComboBoxItemTemplate}"
                    ItemsSource="{Binding PlacementOptions}"
                    SelectedItem="{Binding Placement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Style="{StaticResource SettingsComboBox}" />
            </Grid>
        </Border>

        <Rectangle
            x:Name="DropPlaceholder"
            Margin="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            IsHitTestVisible="False"
            Opacity="0"
            RadiusX="6"
            RadiusY="6"
            Stroke="{StaticResource Brush.Accent.Primary}"
            StrokeDashArray="5 3"
            StrokeDashCap="Round"
            StrokeThickness="1.5"
            Visibility="Collapsed" />
    </Grid>
</UserControl>
