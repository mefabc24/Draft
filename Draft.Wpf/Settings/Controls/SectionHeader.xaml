<UserControl
    x:Class="Draft.Settings.Controls.SectionHeader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Draft.Settings.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <StackPanel>
        <TextBlock
            FontFamily="{StaticResource Font.Inter}"
            FontSize="12"
            FontStretch="UltraCondensed"
            FontWeight="Medium"
            Foreground="{StaticResource Brush.Accent.Primary}"
            Text="{Binding Title, RelativeSource={RelativeSource AncestorType={x:Type local:SectionHeader}}, FallbackValue='Section Header'}" />
        <Border
            Height="1"
            Margin="0,8,0,8"
            Background="{StaticResource Brush.Border.Default}" />
    </StackPanel>
</UserControl>
