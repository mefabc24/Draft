<UserControl
    x:Class="Draft.Settings.Controls.ShortcutRecorder"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i18n="clr-namespace:Draft.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    d:DesignHeight="36"
    d:DesignWidth="220"
    Style="{StaticResource ShortcutRecorderControl}"
    mc:Ignorable="d">
    <Border x:Name="MainBorder" Style="{StaticResource ShortcutRecorderBorder}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Style="{StaticResource ShortcutRecorderText}"
                Text="{Binding DisplayText, ElementName=Root, FallbackValue='CTRL + S'}" />


            <StackPanel Grid.Column="1" Orientation="Horizontal" FlowDirection="RightToLeft">
                <Button
                    x:Name="RecordButton"
                    Margin="0,0,4,0"
                    AutomationProperties.Name="{i18n:Loc shortcuts.recordShortcut}"
                    Click="RecordButton_Click"
                    Style="{StaticResource ShortcutButton}">
                    <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" Style="{StaticResource ShortcutRecorderIcon}" />
                </Button>
                <Button
                    x:Name="ResetButton"
                    AutomationProperties.Name="{i18n:Loc shortcuts.resetShortcut}"
                    Click="ResetButton_Click"
                    ToolTip="{i18n:Loc shortcuts.resetShortcut}"
                    Visibility="{Binding ResetButtonVisibility, ElementName=Root}"
                    Style="{StaticResource ShortcutButton}">
                    <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" Style="{StaticResource ShortcutRestoreIcon}" RenderTransformOrigin="0.5,0.5" >
                        <Path.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="-1"/>
                                <SkewTransform/>
                                <RotateTransform/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>
                </Button>
            </StackPanel>

        </Grid>
    </Border>
</UserControl>
