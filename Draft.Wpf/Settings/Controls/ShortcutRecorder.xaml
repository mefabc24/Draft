<UserControl
    x:Class="Draft.Settings.Controls.ShortcutRecorder"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Draft.Settings.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    d:DesignHeight="36"
    d:DesignWidth="220"
    Focusable="True"
    mc:Ignorable="d">
    <UserControl.Style>
        <Style TargetType="{x:Type local:ShortcutRecorder}">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <UserControl.Resources>
        <SolidColorBrush
            x:Key="ShortcutRecorderActiveBackground"
            Opacity="0.14"
            Color="{StaticResource Color.Function.Critical}" />
        <SolidColorBrush
            x:Key="ShortcutRecorderButtonHoverBackground"
            Opacity="0.08"
            Color="{StaticResource Color.Text.Secondary}" />
        <SolidColorBrush
            x:Key="ShortcutRecorderActiveButtonHoverBackground"
            Opacity="0.16"
            Color="{StaticResource Color.Function.Critical}" />

        <Style x:Key="ShortcutRecordButton" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
            <Setter Property="ToolTip" Value="Record shortcut" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border
                            x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ShortcutRecorderButtonHoverBackground}" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="Foreground" Value="{StaticResource Brush.Icon.SubtleHover}" />
                </Trigger>

                <DataTrigger Binding="{Binding IsRecording, RelativeSource={RelativeSource AncestorType={x:Type local:ShortcutRecorder}}}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource Brush.Function.Critical}" />
                    <Setter Property="ToolTip" Value="Recording shortcut. Click to stop." />
                </DataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                        <Condition Binding="{Binding IsRecording, RelativeSource={RelativeSource AncestorType={x:Type local:ShortcutRecorder}}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource ShortcutRecorderActiveButtonHoverBackground}" />
                    <Setter Property="Foreground" Value="{StaticResource Brush.Function.Critical}" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border
        x:Name="MainBorder"
        MinHeight="36"
        Padding="0"
        SnapsToDevicePixels="True">
        <Border.Style>
            <Style TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{StaticResource Brush.Background.Input}" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Input}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="3" />
                <Setter Property="Effect" Value="{x:Null}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource Brush.Background.InputSubtleHover}" />
                    </Trigger>

                    <DataTrigger Binding="{Binding IsRecording, RelativeSource={RelativeSource AncestorType={x:Type local:ShortcutRecorder}}}" Value="True">
                        <Setter Property="Background" Value="{StaticResource ShortcutRecorderActiveBackground}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Function.Critical}" />
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect
                                    BlurRadius="14"
                                    Opacity="0.34"
                                    ShadowDepth="0"
                                    Color="{StaticResource Color.Function.Critical}" />
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Margin="12,0,8,0"
                VerticalAlignment="Center"
                FontFamily="{StaticResource Font.SpaceGrotesk}"
                FontSize="14"
                FontWeight="Bold"
                Text="{Binding DisplayText, ElementName=Root}"
                TextTrimming="CharacterEllipsis"
                TextWrapping="NoWrap">
                <TextBlock.Style>
                    <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRecording, RelativeSource={RelativeSource AncestorType={x:Type local:ShortcutRecorder}}}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Brush.Function.Critical}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Button
                x:Name="RecordButton"
                Grid.Column="1"
                Margin="0,0,1,0"
                AutomationProperties.Name="Record shortcut"
                Click="RecordButton_Click"
                Style="{StaticResource ShortcutRecordButton}">
                <Path
                    Width="18"
                    Height="18"
                    Data="{StaticResource Icon.Record}"
                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                    Stretch="Uniform" />
            </Button>
        </Grid>
    </Border>
</UserControl>
