<Window
    x:Class="Draft.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:Draft.Controls"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Title="Draft"
    Width="1920"
    Height="1080"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStyle="None"
    mc:Ignorable="d">
    <!--  Window Logic: Native Window Chrome behavior  -->
    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="40"
            GlassFrameThickness="0"
            ResizeBorderThickness="6" />
    </WindowChrome.WindowChrome>

    <!--  Root: App Logic + Window Logic overlay  -->
    <Grid>
        <!--  App Logic  -->
        <Border
            Background="{StaticResource Brush.WindowBG}"
            BorderBrush="{StaticResource Brush.PrimaryAccent}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>

                <!--  App Surface  -->
                <Border Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" MinHeight="50px" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  App Controls  -->
                        <Grid Grid.Row="0" Margin="0,0,0,24">
                            <uc:ControlBar x:Name="ControlBar" WindowChrome.IsHitTestVisibleInChrome="True" />
                        </Grid>

                        <!--  Workspace  -->
                        <Border
                            Grid.Row="1"
                            Background="{StaticResource Brush.Island}"
                            BorderBrush="{StaticResource Brush.Outline}"
                            BorderThickness="1"
                            CornerRadius="16">
                            <Grid>
                                <wv2:WebView2 x:Name="WorkspaceWebView" />

                                <Grid
                                    x:Name="WorkspaceLoaderOverlay"
                                    Panel.ZIndex="1"
                                    Background="{StaticResource Brush.Island}">
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <StackPanel.Resources>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Width" Value="10" />
                                                <Setter Property="Height" Value="10" />
                                                <Setter Property="Margin" Value="5,0" />
                                                <Setter Property="Fill" Value="{StaticResource Brush.PrimaryAccent}" />
                                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <ScaleTransform ScaleX="0.65" ScaleY="0.65" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </StackPanel.Resources>

                                        <Ellipse x:Name="LoaderDotLeft" />
                                        <Ellipse x:Name="LoaderDotMiddle" />
                                        <Ellipse x:Name="LoaderDotRight" />
                                    </StackPanel>

                                    <Grid.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever" Duration="0:0:1.6">
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LoaderDotLeft" Storyboard.TargetProperty="RenderTransform.ScaleX">
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.0" Value="1.35" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="0.65" KeySpline="0.45,0 0.55,1" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:1.2" Value="0.65" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:1.6" Value="1.35" KeySpline="0.45,0 0.55,1" />
                                                    </DoubleAnimationUsingKeyFrames>
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LoaderDotLeft" Storyboard.TargetProperty="RenderTransform.ScaleY">
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.0" Value="1.35" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="0.65" KeySpline="0.45,0 0.55,1" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:1.2" Value="0.65" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:1.6" Value="1.35" KeySpline="0.45,0 0.55,1" />
                                                    </DoubleAnimationUsingKeyFrames>

                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LoaderDotMiddle" Storyboard.TargetProperty="RenderTransform.ScaleX">
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.0" Value="0.65" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="1.35" KeySpline="0.45,0 0.55,1" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="0.65" KeySpline="0.45,0 0.55,1" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:1.2" Value="1.35" KeySpline="0.45,0 0.55,1" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:1.6" Value="0.65" KeySpline="0.45,0 0.55,1" />
                                                    </DoubleAnimationUsingKeyFrames>
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LoaderDotMiddle" Storyboard.TargetProperty="RenderTransform.ScaleY">
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.0" Value="0.65" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="1.35" KeySpline="0.45,0 0.55,1" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="0.65" KeySpline="0.45,0 0.55,1" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:1.2" Value="1.35" KeySpline="0.45,0 0.55,1" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:1.6" Value="0.65" KeySpline="0.45,0 0.55,1" />
                                                    </DoubleAnimationUsingKeyFrames>

                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LoaderDotRight" Storyboard.TargetProperty="RenderTransform.ScaleX">
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.0" Value="0.65" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="0.65" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="1.35" KeySpline="0.45,0 0.55,1" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:1.2" Value="0.65" KeySpline="0.45,0 0.55,1" />
                                                    </DoubleAnimationUsingKeyFrames>
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LoaderDotRight" Storyboard.TargetProperty="RenderTransform.ScaleY">
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.0" Value="0.65" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.4" Value="0.65" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:0.8" Value="1.35" KeySpline="0.45,0 0.55,1" />
                                                        <SplineDoubleKeyFrame KeyTime="0:0:1.2" Value="0.65" KeySpline="0.45,0 0.55,1" />
                                                    </DoubleAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Grid.Triggers>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!--  Status Bar  -->
                <Border
                    Grid.Row="1"
                    Padding="24,8"
                    Background="#131313"
                    BorderBrush="#1A1A1A"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,8,8">
                    <uc:StatusBar />
                </Border>
            </Grid>
        </Border>

        <!--  Window Logic: custom titlebar controls overlay  -->
        <Grid
            Margin="1"
            VerticalAlignment="Top"
            WindowChrome.IsHitTestVisibleInChrome="True">
            <uc:WindowControls HorizontalAlignment="Right" />
        </Grid>
    </Grid>
</Window>
