<Window
    x:Class="Draft.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:Draft.Controls"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Title="Draft"
    Width="1920"
    MinWidth="900"
    Height="1080"
    MinHeight="600"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStyle="None"
    mc:Ignorable="d">
    <!--  Window Logic: Native Window Chrome behavior  -->
    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="96"
            GlassFrameThickness="0"
            ResizeBorderThickness="6" />
    </WindowChrome.WindowChrome>

    <!--  Root: App Logic + Window Logic overlay  -->
    <Grid>
        <!--  App Logic  -->
        <Border
            Background="{StaticResource Brush.WindowBG}"
            BorderBrush="{StaticResource Brush.PrimaryAccent}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>

                <!--  App Surface  -->
                <Border Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" MinHeight="50px" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  App Controls  -->
                        <Grid Grid.Row="0" Margin="0,0,0,24">
                            <uc:ControlBar x:Name="ControlBar" WindowChrome.IsHitTestVisibleInChrome="True" />
                        </Grid>

                        <!--  Workspace  -->
                        <Border
                            Grid.Row="1"
                            Background="{StaticResource Brush.Island}"
                            BorderBrush="{StaticResource Brush.Outline}"
                            BorderThickness="1"
                            CornerRadius="16">
                            <Grid>
                                <wv2:WebView2 x:Name="WorkspaceWebView" DefaultBackgroundColor="transparent" />

                                <Grid
                                    x:Name="WorkspaceLoaderOverlay"
                                    Panel.ZIndex="1"
                                    Background="{StaticResource Brush.Island}">
                                    <uc:LoadingDots
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!--  Status Bar  -->
                <Border
                    Grid.Row="1"
                    Padding="24,8"
                    Background="{StaticResource Brush.Background.Surface}"
                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,8,8">
                    <uc:StatusBar />
                </Border>
            </Grid>
        </Border>

        <!--  Window Logic: custom titlebar controls overlay  -->
        <Grid
            Margin="1"
            VerticalAlignment="Top"
            WindowChrome.IsHitTestVisibleInChrome="True">
            <uc:WindowControls HorizontalAlignment="Right" />
        </Grid>
    </Grid>
</Window>
