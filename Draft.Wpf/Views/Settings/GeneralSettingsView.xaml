<UserControl
    x:Class="Draft.Views.Settings.GeneralSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:section="clr-namespace:Draft.Controls.Settings"
    xmlns:settings="clr-namespace:Draft.Wpf.Controls.Settings"
    d:DesignHeight="2000"
    d:DesignWidth="540"
    mc:Ignorable="d">
    <Border Background="Transparent">
        <ScrollViewer
            HorizontalScrollBarVisibility="Disabled"
            Style="{StaticResource SettingsScrollViewer}"
            VerticalScrollBarVisibility="Auto">
            <StackPanel VerticalAlignment="Top">
                <section:SectionHeader Title="STARTUP &amp; BEHAVIOR" />

                <settings:SettingCard
                    Title="Reopen last workspace on startup"
                    Margin="0,0,0,12"
                    Description="Automatically restore the files and layout from your last session.">
                    <CheckBox IsChecked="{Binding Settings.ReopenLastWorkspaceOnStartup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsCheckBox}" />
                </settings:SettingCard>

                <settings:SettingCard
                    Title="Autosave enabled"
                    Margin="0,0,0,12"
                    Description="Save your changes automatically while you work.">
                    <CheckBox IsChecked="{Binding Settings.AutosaveEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsCheckBox}" />
                </settings:SettingCard>

                <settings:SettingCard
                    Title="Autosave interval"
                    Margin="0,0,0,12"
                    Description="Choose how often Draft should save changes automatically.">
                    <ComboBox
                        Width="160"
                        Height="36"
                        IsEnabled="{Binding Settings.IsAutosaveIntervalEnabled}"
                        ItemsSource="{Binding Settings.AutosaveIntervalOptions}"
                        SelectedItem="{Binding Settings.AutosaveInterval, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource SettingsComboBox}" />
                </settings:SettingCard>

                <settings:SettingCard
                    Title="Save on focus lost"
                    Margin="0,0,0,12"
                    Description="Save the current file when Draft loses focus or you switch away from the app.">
                    <CheckBox IsChecked="{Binding Settings.SaveOnFocusLost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsCheckBox}" />
                </settings:SettingCard>

                <settings:SettingCard
                    Title="Confirm before closing unsaved files"
                    Margin="0,0,0,12"
                    Description="Show a warning before closing files with unsaved changes.">
                    <CheckBox IsChecked="{Binding Settings.ConfirmBeforeClosingUnsavedFiles, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsCheckBox}" />
                </settings:SettingCard>

                <settings:SettingFieldCard Title="Window border accent" Margin="0,0,0,12">
                    <ComboBox
                        Height="36"
                        HorizontalAlignment="Stretch"
                        ItemsSource="{Binding Settings.WindowBorderAccentModeOptions}"
                        SelectedItem="{Binding Settings.WindowBorderAccentMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource SettingsComboBox}" />
                </settings:SettingFieldCard>

                <settings:SettingCard
                    Title="Default startup mode"
                    Margin="0,0,0,12"
                    Description="Choose which workspace mode Draft should open with.">
                    <ComboBox
                        Width="160"
                        Height="36"
                        ItemsSource="{Binding Settings.DefaultStartupModeOptions}"
                        SelectedItem="{Binding Settings.DefaultStartupMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource SettingsComboBox}" />
                </settings:SettingCard>

                <settings:SettingCard
                    Title="Window Minimum Size Scale"
                    Margin="0,0,0,32"
                    Description="Controls how small the main window is allowed to become.">
                    <ComboBox
                        Width="160"
                        Height="36"
                        ItemStringFormat="{}{0:0.0#}"
                        ItemsSource="{Binding Settings.WindowMinimumSizeScaleOptions}"
                        SelectedItem="{Binding Settings.WindowMinimumSizeScale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource SettingsComboBox}" />
                </settings:SettingCard>

                <section:SectionHeader Title="WORKSPACE BEHAVIOR" />

                <settings:SettingFieldCard Title="Scroll sync mode" Margin="0,0,0,12">
                    <ComboBox
                        Height="36"
                        HorizontalAlignment="Stretch"
                        ItemsSource="{Binding Settings.PreviewScrollSyncModeOptions}"
                        SelectedItem="{Binding Settings.PreviewScrollSyncMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource SettingsComboBox}" />
                </settings:SettingFieldCard>

                <settings:SettingFieldCard Title="Floating Markdown toolbar" Margin="0,0,0,32">
                    <ComboBox
                        Height="36"
                        HorizontalAlignment="Stretch"
                        ItemsSource="{Binding Settings.FloatingMarkdownToolbarModeOptions}"
                        SelectedItem="{Binding Settings.FloatingMarkdownToolbarMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource SettingsComboBox}" />
                </settings:SettingFieldCard>

                <section:SectionHeader Title="FILE MANAGEMENT" />

                <settings:SettingFieldCard Title="Default save location" Margin="0,0,0,12">
                    <Grid Height="36">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            Grid.Column="0"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource SettingsTextBox}"
                            Tag="Choose a default save folder"
                            Text="{Binding Settings.DefaultSaveLocationDisplay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <Button
                            Grid.Column="1"
                            Width="96"
                            Margin="8,0,0,0"
                            Command="{Binding Settings.BrowseDefaultSaveLocationCommand}"
                            Content="Browse"
                            Style="{StaticResource SettingButton}" />
                    </Grid>
                </settings:SettingFieldCard>

                <settings:SettingFieldCard Title="Default file extension" Margin="0,0,0,12">
                    <ComboBox
                        Height="36"
                        HorizontalAlignment="Stretch"
                        IsEnabled="False"
                        ItemsSource="{Binding Settings.DefaultFileExtensionOptions}"
                        SelectedItem="{Binding Settings.DefaultFileExtension, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource SettingsComboBox}" />
                </settings:SettingFieldCard>

                <settings:SettingCard
                    Title="Associate .txt files with Draft"
                    Margin="0,0,0,12"
                    Description="Allow Draft to appear as an option for opening plain text files.">
                    <CheckBox IsChecked="{Binding Settings.AssociateTxtFilesWithDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsCheckBox}" />
                </settings:SettingCard>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
