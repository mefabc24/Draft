<Window
    x:Class="Draft.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settings="clr-namespace:Draft.Views.Settings"
    xmlns:settingsVm="clr-namespace:Draft.ViewModels"
    Title="Settings"
    Width="900"
    Height="600"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStyle="None"
    mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Settings/SettingsTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type settingsVm:GeneralSettingsPageViewModel}">
                <settings:GeneralSettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type settingsVm:EditorSettingsPageViewModel}">
                <settings:EditorSettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type settingsVm:PreviewSettingsPageViewModel}">
                <settings:PreviewSettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type settingsVm:AppearanceSettingsPageViewModel}">
                <settings:AppearanceSettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type settingsVm:AboutSettingsPageViewModel}">
                <settings:AboutSettingsView />
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="48"
            GlassFrameThickness="0"
            ResizeBorderThickness="6" />
    </WindowChrome.WindowChrome>

    <Border
        Background="{StaticResource Brush.WindowBG}"
        BorderThickness="1"
        CornerRadius="8">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="{StaticResource Brush.PrimaryAccent}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                        <Setter Property="BorderBrush" Value="#3D3D3D" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Side Menu -->
            <Border Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock
                            FontFamily="{StaticResource Font.Manrope}"
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="{StaticResource Brush.PrimaryAccent}"
                            Text="Settings" />
                        <TextBlock
                            FontFamily="{StaticResource Font.Inter}"
                            FontSize="11"
                            FontWeight="Regular"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="Configuration" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,32">
                        <RadioButton
                            Height="36"
                            Margin="0,0,0,4"
                            GroupName="SettingsMenu"
                            IsChecked="{Binding IsGeneralSettingsSelected, Mode=TwoWay}"
                            Style="{StaticResource SettingsMenuRadioButton}">
                            <StackPanel Orientation="Horizontal">
                                <Path
                                    Width="16"
                                    Height="16"
                                    Data="{StaticResource Icon.Settings}"
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                    Stretch="Uniform" />
                                <TextBlock Margin="12,0,0,0" Text="General" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton
                            Height="36"
                            Margin="0,0,0,4"
                            GroupName="SettingsMenu"
                            IsChecked="{Binding IsEditorSettingsSelected, Mode=TwoWay}"
                            Style="{StaticResource SettingsMenuRadioButton}">
                            <StackPanel Orientation="Horizontal">
                                <Path
                                    Width="16"
                                    Height="16"
                                    Data="{StaticResource Icon.Editor}"
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                    Stretch="Uniform" />
                                <TextBlock Margin="12,0,0,0" Text="Editor" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton
                            Height="36"
                            Margin="0,0,0,4"
                            GroupName="SettingsMenu"
                            IsChecked="{Binding IsPreviewSettingsSelected, Mode=TwoWay}"
                            Style="{StaticResource SettingsMenuRadioButton}">
                            <StackPanel Orientation="Horizontal">
                                <Path
                                    Width="16"
                                    Height="16"
                                    Data="{StaticResource Icon.Preview}"
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                    Stretch="Uniform" />
                                <TextBlock Margin="12,0,0,0" Text="Preview" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton
                            Height="36"
                            Margin="0,0,0,4"
                            GroupName="SettingsMenu"
                            IsChecked="{Binding IsAppearanceSettingsSelected, Mode=TwoWay}"
                            Style="{StaticResource SettingsMenuRadioButton}">
                            <StackPanel Orientation="Horizontal">
                                <Path
                                    Width="16"
                                    Height="16"
                                    Data="{StaticResource Icon.Appearance}"
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                    Stretch="Uniform" />
                                <TextBlock Margin="12,0,0,0" Text="Appearance" />
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>

                    <RadioButton
                        Grid.Row="2"
                        Height="36"
                        GroupName="SettingsMenu"
                        IsChecked="{Binding IsAboutSettingsSelected, Mode=TwoWay}"
                        Style="{StaticResource SettingsMenuRadioButton}">
                        <StackPanel Orientation="Horizontal">
                            <Path
                                Width="16"
                                Height="16"
                                Data="{StaticResource Icon.About}"
                                Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                Stretch="Uniform" />
                            <TextBlock Margin="12,0,0,0" Text="About" />
                        </StackPanel>
                    </RadioButton>
                </Grid>
            </Border>

            <!-- Divider -->
            <Border Grid.Column="1" Background="{StaticResource Brush.Border.Default}" />


            <!-- Content -->
            <Border Grid.Column="2" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            FontFamily="{StaticResource Font.Manrope}"
                            FontSize="32"
                            FontWeight="Bold"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding CurrentSettingsPage.Title, FallbackValue='Page Titel'}" />

                        <!-- Close Button -->
                        <Button
                            Grid.Column="1"
                            VerticalAlignment="Top"
                            Click="CloseButton_Click"
                            Style="{StaticResource SettingsCloseButton}"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                            <Path
                                Width="8"
                                Height="8"
                                Data="{StaticResource Icon.Close}"
                                Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                Stretch="Uniform" />
                        </Button>
                    </Grid>

                    <ContentControl Grid.Row="1" Content="{Binding CurrentSettingsPage}" />

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button
                            Margin="0,16,0,0"
                            Padding="24,0"
                            VerticalAlignment="Stretch"
                            Command="{Binding CancelSettingsCommand}"
                            Content="Reset to Defaults"
                            Style="{StaticResource SettingsSecondaryButton}" />

                        <StackPanel
                            Grid.Column="1"
                            Height="30"
                            Margin="0,16,0,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                            <Button
                                Margin="0,0,16,0"
                                Padding="24,0"
                                VerticalAlignment="Stretch"
                                Command="{Binding CancelSettingsCommand}"
                                Content="Cancel"
                                Style="{StaticResource SettingsSecondaryButton}" />
                            <Button
                                Padding="24,0"
                                VerticalAlignment="Stretch"
                                Command="{Binding ApplySettingsCommand}"
                                Content="Apply Changes"
                                Style="{StaticResource SettingsPrimaryButton}" />
                        </StackPanel>
                    </Grid>

                </Grid>
            </Border>



        </Grid>
    </Border>

</Window>
