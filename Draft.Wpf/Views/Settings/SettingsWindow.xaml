<Window
    x:Class="Draft.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settings="clr-namespace:Draft.Views.Settings"
    xmlns:settingsVm="clr-namespace:Draft.ViewModels"
    Title="Settings"
    Width="900"
    Height="600"
    AllowsTransparency="True"
    Background="Transparent"
    Icon="/Assets/Icons/draft.ico"
    WindowStyle="None"
    mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary>
            <DataTemplate DataType="{x:Type settingsVm:GeneralSettingsPageViewModel}">
                <settings:GeneralSettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type settingsVm:EditorSettingsPageViewModel}">
                <settings:EditorSettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type settingsVm:PreviewSettingsPageViewModel}">
                <settings:PreviewSettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type settingsVm:AppearanceSettingsPageViewModel}">
                <settings:AppearanceSettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type settingsVm:DevelopSettingsPageViewModel}">
                <settings:DevelopSettingsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type settingsVm:AboutSettingsPageViewModel}">
                <settings:AboutSettingsView />
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="48"
            GlassFrameThickness="0"
            ResizeBorderThickness="6" />
    </WindowChrome.WindowChrome>

    <Border x:Name="SettingsWindowFrameBorder" Background="{StaticResource Brush.Island}">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.SettingsWindow.Active}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.SettingsWindow.Inactive}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding AppliedWindowBorderAccentMode}" Value="Always">
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.PrimaryAccent}" />
                    </DataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding AppliedWindowBorderAccentMode}" Value="FocusedWindowOnly" />
                            <Condition Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.PrimaryAccent}" />
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding AppliedWindowBorderAccentMode}" Value="UnfocusedWindowsOnly" />
                            <Condition Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.PrimaryAccent}" />
                    </MultiDataTrigger>
                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="CornerRadius" Value="0" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Side Menu -->
            <Border Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                FontFamily="{StaticResource Font.Manrope}"
                                FontSize="20"
                                FontWeight="Bold"
                                Foreground="{StaticResource Brush.PrimaryAccent}"
                                Text="Settings" />
                            <Button
                                Grid.Column="1"
                                Padding="24,0"
                                VerticalAlignment="Stretch"
                                Command="{Binding ResetToDefaultsCommand}"
                                Style="{StaticResource RestoreSettingsButton}"
                                ToolTip="Restore Default Settings"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                                <Path
                                    Width="12"
                                    Height="12"
                                    Data="{StaticResource Icon.Undo}"
                                    Fill="{StaticResource Brush.Text.Secondary}"
                                    Stretch="Uniform" />
                            </Button>
                        </Grid>

                        <TextBlock
                            FontFamily="{StaticResource Font.Inter}"
                            FontSize="11"
                            FontWeight="Regular"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="Configuration" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,32">
                        <RadioButton
                            Height="36"
                            Margin="0,0,0,4"
                            GroupName="SettingsMenu"
                            IsChecked="{Binding IsGeneralSettingsSelected, Mode=TwoWay}"
                            Style="{StaticResource SettingsMenuRadioButton}">
                            <StackPanel Orientation="Horizontal">
                                <Path
                                    Width="16"
                                    Height="16"
                                    Data="{StaticResource Icon.Settings}"
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                    Stretch="Uniform" />
                                <TextBlock Margin="12,0,0,0" Text="General" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton
                            Height="36"
                            Margin="0,0,0,4"
                            GroupName="SettingsMenu"
                            IsChecked="{Binding IsEditorSettingsSelected, Mode=TwoWay}"
                            Style="{StaticResource SettingsMenuRadioButton}">
                            <StackPanel Orientation="Horizontal">
                                <Path
                                    Width="16"
                                    Height="16"
                                    Data="{StaticResource Icon.Editor}"
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                    Stretch="Uniform" />
                                <TextBlock Margin="12,0,0,0" Text="Editor" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton
                            Height="36"
                            Margin="0,0,0,4"
                            GroupName="SettingsMenu"
                            IsChecked="{Binding IsPreviewSettingsSelected, Mode=TwoWay}"
                            Style="{StaticResource SettingsMenuRadioButton}">
                            <StackPanel Orientation="Horizontal">
                                <Path
                                    Width="16"
                                    Height="16"
                                    Data="{StaticResource Icon.Preview}"
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                    Stretch="Uniform" />
                                <TextBlock Margin="12,0,0,0" Text="Preview" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton
                            Height="36"
                            Margin="0,0,0,4"
                            GroupName="SettingsMenu"
                            IsChecked="{Binding IsAppearanceSettingsSelected, Mode=TwoWay}"
                            Style="{StaticResource SettingsMenuRadioButton}">
                            <StackPanel Orientation="Horizontal">
                                <Path
                                    Width="16"
                                    Height="16"
                                    Data="{StaticResource Icon.Appearance}"
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                    Stretch="Uniform" />
                                <TextBlock Margin="12,0,0,0" Text="Appearance" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton
                            Height="36"
                            Margin="0,0,0,4"
                            GroupName="SettingsMenu"
                            IsChecked="{Binding IsDevelopSettingsSelected, Mode=TwoWay}">
                            <RadioButton.Style>
                                <Style BasedOn="{StaticResource SettingsMenuRadioButton}" TargetType="RadioButton">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDevelopSettingsVisible}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </RadioButton.Style>
                            <StackPanel Orientation="Horizontal">
                                <Path
                                    Width="16"
                                    Height="16"
                                    Data="{StaticResource Icon.Terminal}"
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                    Stretch="Uniform" />
                                <TextBlock Margin="12,0,0,0" Text="Develop" />
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>

                    <RadioButton
                        Grid.Row="2"
                        Height="36"
                        GroupName="SettingsMenu"
                        IsChecked="{Binding IsAboutSettingsSelected, Mode=TwoWay}"
                        Style="{StaticResource SettingsMenuRadioButton}">
                        <StackPanel Orientation="Horizontal">
                            <Path
                                Width="16"
                                Height="16"
                                Data="{StaticResource Icon.About}"
                                Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                Stretch="Uniform" />
                            <TextBlock Margin="12,0,0,0" Text="About" />
                        </StackPanel>
                    </RadioButton>
                </Grid>
            </Border>

            <!-- Divider -->
            <Border Grid.Column="1" Background="{StaticResource Brush.Border.Default}" />


            <!-- Content -->
            <Border Grid.Column="2" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            FontFamily="{StaticResource Font.Manrope}"
                            FontSize="32"
                            FontWeight="Bold"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding CurrentSettingsPage.Title, FallbackValue='Page Title'}" />

                        <!-- Close Button -->
                        <Button
                            Grid.Column="1"
                            VerticalAlignment="Top"
                            Click="CloseButton_Click"
                            Style="{StaticResource DraftCloseButton}"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                            <Path
                                Width="12"
                                Height="12"
                                Data="{StaticResource Icon.Close}"
                                Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                Stretch="Uniform" />
                        </Button>
                    </Grid>

                    <ContentControl Grid.Row="1" Content="{Binding CurrentSettingsPage}" Margin="0,16"/>

                    <Grid Grid.Row="2">
                        <StackPanel
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                            <Button
                                Width="160"
                                Margin="0,0,16,0"
                                Padding="24,0"
                                VerticalAlignment="Stretch"
                                Command="{Binding CancelSettingsCommand}"
                                Content="Cancel"
                                Style="{StaticResource MessageDialogSecondaryButton}" />
                            <Button
                                Width="160"
                                Padding="24,0"
                                VerticalAlignment="Stretch"
                                Command="{Binding ApplySettingsCommand}"
                                Content="Apply Changes"
                                Style="{StaticResource MessageDialogPrimaryButton}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
