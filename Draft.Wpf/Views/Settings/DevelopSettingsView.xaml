<UserControl
    x:Class="Draft.Views.Settings.DevelopSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:section="clr-namespace:Draft.Controls.Settings"
    xmlns:settings="clr-namespace:Draft.Wpf.Controls.Settings"
    d:DesignHeight="2000"
    d:DesignWidth="540"
    mc:Ignorable="d">
    <Grid Background="Transparent">
        <Border Background="Transparent">
            <ScrollViewer
                HorizontalScrollBarVisibility="Disabled"
                Style="{StaticResource SettingsScrollViewer}"
                VerticalScrollBarVisibility="Auto">
                <StackPanel VerticalAlignment="Top">
                    <section:SectionHeader Title="Dialog Previews" />

                    <settings:SettingCard
                        Title="Info dialog"
                        Margin="0,0,0,12"
                        Description="Open the info dialog variant.">
                        <StackPanel Orientation="Horizontal">
                            <ComboBox
                                Width="72"
                                Height="36"
                                Margin="0,0,8,0"
                                ItemsSource="{Binding DialogButtonCountOptions}"
                                SelectedItem="{Binding InfoDialogButtonCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource SettingsComboBox}" />
                            <Button
                                Width="120"
                                Height="36"
                                Command="{Binding ShowInfoDialogCommand}"
                                Content="Open"
                                Style="{StaticResource SettingButton}" />
                        </StackPanel>
                    </settings:SettingCard>

                    <settings:SettingCard
                        Title="Warning dialog"
                        Margin="0,0,0,12"
                        Description="Open the warning dialog variant.">
                        <StackPanel Orientation="Horizontal">
                            <ComboBox
                                Width="72"
                                Height="36"
                                Margin="0,0,8,0"
                                ItemsSource="{Binding DialogButtonCountOptions}"
                                SelectedItem="{Binding WarningDialogButtonCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource SettingsComboBox}" />
                            <Button
                                Width="120"
                                Height="36"
                                Command="{Binding ShowWarningDialogCommand}"
                                Content="Open"
                                Style="{StaticResource SettingButton}" />
                        </StackPanel>
                    </settings:SettingCard>

                    <settings:SettingCard
                        Title="Error dialog"
                        Margin="0,0,0,12"
                        Description="Open the error dialog variant.">
                        <StackPanel Orientation="Horizontal">
                            <ComboBox
                                Width="72"
                                Height="36"
                                Margin="0,0,8,0"
                                ItemsSource="{Binding DialogButtonCountOptions}"
                                SelectedItem="{Binding ErrorDialogButtonCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource SettingsComboBox}" />
                            <Button
                                Width="120"
                                Height="36"
                                Command="{Binding ShowErrorDialogCommand}"
                                Content="Open"
                                Style="{StaticResource SettingButton}" />
                        </StackPanel>
                    </settings:SettingCard>

                    <settings:SettingCard
                        Title="Success dialog"
                        Margin="0,0,0,12"
                        Description="Open the success dialog variant.">
                        <StackPanel Orientation="Horizontal">
                            <ComboBox
                                Width="72"
                                Height="36"
                                Margin="0,0,8,0"
                                ItemsSource="{Binding DialogButtonCountOptions}"
                                SelectedItem="{Binding SuccessDialogButtonCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource SettingsComboBox}" />
                            <Button
                                Width="120"
                                Height="36"
                                Command="{Binding ShowSuccessDialogCommand}"
                                Content="Open"
                                Style="{StaticResource SettingButton}" />
                        </StackPanel>
                    </settings:SettingCard>

                    <section:SectionHeader Title="Update Card Demo" />

                    <settings:UpdateSettingCard
                        Title="Test update card"
                        Margin="0,0,0,12"
                        ActionCommand="{Binding RunDemoUpdateActionCommand}"
                        ActionText="{Binding DemoUpdateActionText}"
                        Description="Development-only test setting card. It always reports a fake update and never installs anything."
                        IsActionEnabled="{Binding IsDemoUpdateActionEnabled}"
                        IsUpdateAvailable="{Binding IsDemoUpdateAvailable}"
                        StatusText="{Binding DemoUpdateStatus}" />

                    <section:SectionHeader Title="Prompt Preview" />

                    <settings:SettingCard
                        Title="Prompt window"
                        Margin="0,0,0,12"
                        Description="Open the empty prompt window shell.">
                        <Button
                            Width="120"
                            Height="36"
                            Command="{Binding ShowPromptWindowCommand}"
                            Content="Open"
                            Style="{StaticResource SettingButton}" />
                    </settings:SettingCard>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
