<UserControl
    x:Class="Draft.Views.Settings.AboutSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Draft.Views.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:section="clr-namespace:Draft.Controls.Settings"
    xmlns:settings="clr-namespace:Draft.Wpf.Controls.Settings"
    d:DesignHeight="2000"
    d:DesignWidth="540"
    mc:Ignorable="d">
    <Border Background="Transparent">
        <ScrollViewer
            HorizontalScrollBarVisibility="Disabled"
            Style="{StaticResource SettingsScrollViewer}"
            VerticalScrollBarVisibility="Auto">
            <StackPanel VerticalAlignment="Top">
                <section:SectionHeader Title="DRAFT" />

                <settings:SettingCard Title="A focused Markdown editor for writing, previewing, and saving clean Markdown documents in a calm desktop workspace." Margin="0,0,0,32" />

                <section:SectionHeader Title="VERSION &amp; UPDATES" />
                <settings:SettingCard
                    Title="Version"
                    Margin="0,0,0,12"
                    Description="{Binding VersionDescription, RelativeSource={RelativeSource AncestorType={x:Type local:AboutSettingsView}}, FallbackValue='Version 1.0.0'}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource Font.Manrope}"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{Binding UpdateStatus, RelativeSource={RelativeSource AncestorType={x:Type local:AboutSettingsView}}}"
                            TextWrapping="Wrap" />

                        <Button
                            Grid.Column="1"
                            Width="132"
                            Height="36"
                            Click="CheckForUpdatesButton_Click"
                            Content="Check for updates"
                            IsEnabled="{Binding IsCheckForUpdatesEnabled, RelativeSource={RelativeSource AncestorType={x:Type local:AboutSettingsView}}}"
                            Style="{StaticResource SettingsSecondaryButton}" />
                    </Grid>
                </settings:SettingCard>

                <section:SectionHeader Title="PROJECT &amp; LINKS" />
                <settings:SettingCard Title="GitHub" Description="Open the Draft project repository.">
                    <Button
                        Width="132"
                        Height="36"
                        Click="GitHubButton_Click"
                        Content="Open GitHub"
                        Style="{StaticResource SettingsSecondaryButton}" />
                </settings:SettingCard>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
