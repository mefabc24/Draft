<UserControl
    x:Class="Draft.Views.Settings.PreviewSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:section="clr-namespace:Draft.Controls.Settings"
    xmlns:settings="clr-namespace:Draft.Wpf.Controls.Settings"
    d:DesignHeight="500"
    d:DesignWidth="540"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Settings/SettingsTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="Transparent">
        <ScrollViewer
            HorizontalScrollBarVisibility="Disabled"
            Style="{StaticResource SettingsScrollViewer}"
            VerticalScrollBarVisibility="Auto">
            <StackPanel VerticalAlignment="Top">
                <section:SectionHeader Title="RENDERING" />

                <settings:SettingFieldCard Margin="0,0,0,32" Title="Markdown theme">
                    <ComboBox
                        Height="36"
                        HorizontalAlignment="Stretch"
                        IsEnabled="False"
                        ItemsSource="{Binding Settings.MarkdownThemeOptions}"
                        SelectedItem="{Binding Settings.MarkdownTheme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource SettingsComboBox}" />
                </settings:SettingFieldCard>

                <section:SectionHeader Title="LINKS &amp; SECURITY" />

                <settings:SettingCard
                    Margin="0,0,0,12"
                    Title="Open links in browser"
                    Description="Open clicked links in your default external browser.">
                    <CheckBox
                        IsChecked="{Binding Settings.OpenLinksInBrowser, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource SettingsCheckBox}" />
                </settings:SettingCard>

                <settings:SettingCard
                    Margin="0,0,0,32"
                    Title="Confirm before opening external links"
                    Description="Ask for confirmation before opening links outside Draft.">
                    <CheckBox
                        IsChecked="{Binding Settings.ConfirmBeforeOpeningExternalLinks, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource SettingsCheckBox}" />
                </settings:SettingCard>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
