<Window
    x:Class="Draft.Shell.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:Draft.Shell.Controls"
    xmlns:sharedControls="clr-namespace:Draft.Shared.UI.Controls"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Title="Draft"
    d:Height="500"
    AllowsTransparency="True"
    Background="Transparent"
    Icon="/Assets/Icons/draft.ico"
    WindowStyle="None"
    mc:Ignorable="d">
    <!-- Window Logic: Native Window Chrome behavior -->
    <WindowChrome.WindowChrome>
        <WindowChrome
            x:Name="MainWindowChrome"
            CaptionHeight="96"
            CornerRadius="8"
            GlassFrameThickness="0"
            ResizeBorderThickness="6" />
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding
            Key="S"
            Command="{Binding SaveFileCommand}"
            Modifiers="Control" />
    </Window.InputBindings>

    <!-- Root: App Logic + Window Logic overlay -->
    <Grid x:Name="RootGrid">
        <!-- App Logic -->
        <Border x:Name="WindowFrameBorder" Background="{StaticResource Brush.WindowBG}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.MainWindow.Active}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="CornerRadius" Value="8" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.MainWindow.Inactive}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding WindowBorderAccentMode}" Value="Always">
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.PrimaryAccent}" />
                        </DataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding WindowBorderAccentMode}" Value="FocusedWindowOnly" />
                                <Condition Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.PrimaryAccent}" />
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding WindowBorderAccentMode}" Value="UnfocusedWindowsOnly" />
                                <Condition Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.PrimaryAccent}" />
                        </MultiDataTrigger>
                        <DataTrigger Binding="{Binding IsWindowSnapped, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                            <Setter Property="CornerRadius" Value="0" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="CornerRadius" Value="0" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>

                <!-- App Surface -->
                <Border Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" MinHeight="50px" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- App Controls -->
                        <Grid Grid.Row="0" Margin="0,0,0,24">
                            <uc:ControlBar x:Name="ControlBar" WindowChrome.IsHitTestVisibleInChrome="True" />
                        </Grid>

                        <!-- Workspace -->
                        <Border
                            Grid.Row="1"
                            Panel.ZIndex="0"
                            Background="{StaticResource Brush.Island}"
                            BorderBrush="{StaticResource Brush.Outline}"
                            BorderThickness="1"
                            CornerRadius="16">
                            <Grid>
                                <wv2:WebView2 x:Name="WorkspaceWebView" DefaultBackgroundColor="transparent" />

                                <Grid
                                    x:Name="WorkspaceLoaderOverlay"
                                    Panel.ZIndex="1"
                                    Background="{StaticResource Brush.Island}">
                                    <sharedControls:LoadingDots HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Status Bar -->
                <Border
                    x:Name="StatusBarBorder"
                    Grid.Row="1"
                    Padding="24,4"
                    Panel.ZIndex="10"
                    Background="{StaticResource Brush.Background.Surface}"
                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                    BorderThickness="0,1,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="0,0,8,8" />
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStatusBarVisible}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsWindowSnapped, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                    <Setter Property="CornerRadius" Value="0" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                                    <Setter Property="CornerRadius" Value="0" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <uc:StatusBar x:Name="MainStatusBar" />
                </Border>
            </Grid>
        </Border>

        <!-- Window Logic: custom titlebar controls overlay -->
        <Grid
            VerticalAlignment="Top"
            Panel.ZIndex="20"
            WindowChrome.IsHitTestVisibleInChrome="True">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Margin" Value="1" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsWindowSnapped, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                            <Setter Property="Margin" Value="0" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                            <Setter Property="Margin" Value="0" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <uc:WindowControls HorizontalAlignment="Right" />
        </Grid>

    </Grid>
</Window>
