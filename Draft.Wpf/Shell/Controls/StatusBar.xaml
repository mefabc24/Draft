<UserControl
    x:Class="Draft.Shell.Controls.StatusBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i18n="clr-namespace:Draft.Localization"
    xmlns:local="clr-namespace:Draft.Shell.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignWidth="1200"
    mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="StatusBarVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="0,0,0,1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>

        <!-- Left -->
        <StackPanel Grid.Column="0" Orientation="Horizontal">

            <!-- File Type -->
            <StackPanel
                Height="16"
                Margin="8,0,32,0"
                Orientation="Horizontal"
                Visibility="{Binding IsStatusBarFileTypeVisible, Converter={StaticResource StatusBarVisibilityConverter}}">
                <Path
                    Width="16"
                    Height="16"
                    Margin="0,0,8,0"
                    Data="{StaticResource Icon.Markdown}"
                    Fill="{StaticResource Brush.SecondaryAccent}"
                    Stretch="Uniform" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Font.Manrope}"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource Brush.SecondaryAccent}"
                    Text="{i18n:Loc status.fileTypeMarkdown}" />
            </StackPanel>

            <!-- Encoding Type -->
            <StackPanel
                Height="16"
                Orientation="Horizontal"
                Visibility="{Binding IsStatusBarEncodingVisible, Converter={StaticResource StatusBarVisibilityConverter}}">
                <Path
                    Width="14"
                    Height="14"
                    Margin="0,0,8,0"
                    Data="{StaticResource Icon.Encoding}"
                    Fill="{StaticResource Brush.PrimaryText}"
                    Stretch="Uniform" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Font.Manrope}"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource Brush.PrimaryText}"
                    Text="UTF-8" />
            </StackPanel>


            <!-- Word Count -->

            <StackPanel
                Height="16"
                Margin="32,0"
                Orientation="Horizontal"
                Visibility="{Binding IsStatusBarWordCountVisible, Converter={StaticResource StatusBarVisibilityConverter}}">
                <Path
                    Width="14"
                    Height="14"
                    Margin="0,0,8,0"
                    Data="{StaticResource Icon.File}"
                    Fill="{StaticResource Brush.PrimaryText}"
                    Stretch="Uniform" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Font.Manrope}"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource Brush.PrimaryText}"
                    Text="{Binding WordCountDisplay, FallbackValue='69 WORDS'}" />
            </StackPanel>


            <!-- Character Count -->
            <StackPanel
                Height="16"
                Orientation="Horizontal"
                Visibility="{Binding IsStatusBarCharacterCountVisible, Converter={StaticResource StatusBarVisibilityConverter}}">
                <Path
                    Width="16"
                    Height="16"
                    Margin="0,0,8,0"
                    Data="{StaticResource Icon.Chars}"
                    Fill="{StaticResource Brush.PrimaryText}"
                    Stretch="Uniform" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Font.Manrope}"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource Brush.PrimaryText}"
                    Text="{Binding CharacterCountDisplay, FallbackValue='0 CHARS'}" />
            </StackPanel>
        </StackPanel>

        <!-- Right -->

        <!-- Editor Position -->
        <StackPanel Grid.Column="2" Orientation="Horizontal">
            <Button
                Margin="16,0"
                Padding="8,4"
                Command="{Binding OpenCursorPositionPromptCommand}"
                Style="{StaticResource StatusBarButton}"
                ToolTip="{i18n:Loc status.goToLineOrColumn}"
                Visibility="{Binding IsStatusBarCursorPositionVisible, Converter={StaticResource StatusBarVisibilityConverter}}">
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Font.Manrope}"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource Brush.PrimaryText}"
                    Text="{Binding CursorPositionDisplay, FallbackValue='LN 1, COL 1'}" />
            </Button>

            <!-- Revert Button -->
            <Button
                Padding="8,4"
                Command="{Binding OpenRevertSavePromptCommand}"
                Style="{StaticResource StatusBarButton}"
                ToolTip="{i18n:Loc status.revertToSavedVersion}"
                Visibility="{Binding IsStatusBarRevertButtonVisible, Converter={StaticResource StatusBarVisibilityConverter}}">
                <StackPanel Height="16" Orientation="Horizontal">
                    <Path
                        Width="14"
                        Height="14"
                        Margin="0,0,8,0"
                        Data="{StaticResource Icon.Undo}"
                        Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Stretch="Uniform" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Font.Manrope}"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Text="{i18n:Loc status.revert}" />
                </StackPanel>
            </Button>

            <!-- Save Status -->
            <Button
                Margin="16,0"
                Padding="8,4"
                Command="{Binding SaveFileCommand}"
                Style="{StaticResource StatusBarButton}"
                ToolTip="{i18n:Loc status.saveFile}"
                Visibility="{Binding IsStatusBarSaveStatusVisible, Converter={StaticResource StatusBarVisibilityConverter}}">
                <StackPanel Height="16" Orientation="Horizontal">
                    <Path
                        Width="14"
                        Height="14"
                        Margin="0,0,8,0"
                        Data="{StaticResource Icon.Save}"
                        Stretch="Uniform"
                        Style="{StaticResource FileSaveStatusPathStyle}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Font.Manrope}"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Style="{StaticResource FileSaveStatusTextStyle}"
                        Text="{Binding FileSaveStatusDisplay, FallbackValue='UNSAVED'}" />
                </StackPanel>
            </Button>

            <!-- Autosave Status -->
            <Button
                x:Name="AutosaveModeButton"
                Padding="8,4"
                Command="{Binding OpenAutosavePromptCommand}"
                Style="{StaticResource StatusBarButton}"
                Visibility="{Binding IsStatusBarAutosaveStatusVisible, Converter={StaticResource StatusBarVisibilityConverter}}">
                <StackPanel Height="16" Orientation="Horizontal">
                    <Path
                        Width="16"
                        Height="16"
                        Margin="0,0,8,0"
                        Data="{StaticResource Icon.Sync}"
                        Stretch="Uniform"
                        Style="{StaticResource AutosaveModePathStyle}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Font.Manrope}"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Style="{StaticResource AutosaveModeTextStyle}"
                        Text="{Binding AutosaveModeDisplay, FallbackValue='MANUAL SAVE'}" />
                </StackPanel>
            </Button>

            <!-- App Version -->
            <Button
                Margin="16,0,0,0"
                Padding="8,4"
                Command="{Binding OpenAboutSettingsCommand}"
                Style="{StaticResource StatusBarButton}"
                ToolTip="{i18n:Loc status.openAboutSettings}"
                Visibility="{Binding IsStatusBarAppVersionVisible, Converter={StaticResource StatusBarVisibilityConverter}}">
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Font.Manrope}"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource Brush.PrimaryText}"
                    Text="{Binding AppVersionDisplay, FallbackValue='2.0.0'}" />
            </Button>

        </StackPanel>
    </Grid>
</UserControl>
