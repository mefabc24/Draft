<UserControl
    x:Class="Draft.Shell.Controls.ControlBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i18n="clr-namespace:Draft.Localization"
    xmlns:local="clr-namespace:Draft.Shell.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="clr-namespace:Draft.Shared.UI.Controls"
    mc:Ignorable="d">
    <Border
        Padding="8"
        HorizontalAlignment="Center"
        Background="{StaticResource Brush.Island}"
        BorderBrush="{StaticResource Brush.Outline}"
        BorderThickness="1"
        CornerRadius="8">
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Logo -->
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <!-- Logo -->
            <Button
                Margin="0,0,8,0"
                Click="LogoButton_Click"
                Content="{i18n:Loc app.name}"
                Style="{StaticResource LogoButton}"
                ui:ToolTipAssist.Text="{i18n:Loc settings.about.openGitHub}" />

            <!-- Divider -->
            <Border Grid.Column="1" Background="{StaticResource Brush.Background.Hover}" />

            <!-- Workspace Mode Buttons -->
            <StackPanel
                Grid.Column="2"
                Margin="8,0"
                Orientation="Horizontal">
                <!-- Editor -->
                <RadioButton
                    Content="{i18n:Loc workspace.editor}"
                    GroupName="WorkspaceMode"
                    IsChecked="{Binding IsEditorState, Mode=TwoWay}"
                    Style="{StaticResource ControlRadioButton}" />
                <!-- Split -->
                <RadioButton
                    Margin="8,0"
                    Content="{i18n:Loc workspace.split}"
                    GroupName="WorkspaceMode"
                    IsChecked="{Binding IsSplitState, Mode=TwoWay}"
                    Style="{StaticResource ControlRadioButton}" />
                <!-- Preview -->
                <RadioButton
                    Content="{i18n:Loc workspace.preview}"
                    GroupName="WorkspaceMode"
                    IsChecked="{Binding IsPreviewState, Mode=TwoWay}"
                    Style="{StaticResource ControlRadioButton}" />
            </StackPanel>

            <!-- Divider -->
            <Border Grid.Column="3" Background="{StaticResource Brush.Background.Hover}" />

            <!-- Action Buttons -->
            <StackPanel
                Grid.Column="4"
                Margin="8,0"
                Orientation="Horizontal">
                <!-- Open Button -->
                <Button
                    Margin="0,0,8,0"
                    Command="{Binding OpenFileCommand}"
                    Style="{StaticResource ControlButton}"
                    ui:ToolTipAssist.Shortcut="{Binding OpenShortcut}"
                    ui:ToolTipAssist.Text="{i18n:Loc common.open}">
                    <Path
                        Width="16"
                        Height="16"
                        Data="{StaticResource Icon.Folder}"
                        Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Stretch="Uniform" />
                </Button>
                <!-- Save Button -->
                <Button
                    Margin="0,0,8,0"
                    Command="{Binding SaveFileCommand}"
                    Style="{StaticResource ControlButton}"
                    ui:ToolTipAssist.Shortcut="{Binding SaveShortcut}"
                    ui:ToolTipAssist.Text="{i18n:Loc common.save}">
                    <Grid>
                        <Path
                            Width="16"
                            Height="16"
                            Data="{StaticResource Icon.Save}"
                            Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Stretch="Uniform" />
                        <Canvas>
                            <Ellipse
                                Canvas.Top="-5"
                                Canvas.Right="-5"
                                Width="12"
                                Height="12"
                                Fill="{Binding Path=(local:ControlButtonAssist.CutoutBackground), RelativeSource={RelativeSource AncestorType=Button}}">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SaveStatusDotVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <Ellipse
                                Canvas.Top="-4"
                                Canvas.Right="-4"
                                Width="10"
                                Height="10">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource Brush.Function.Success}" />
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SaveStatusDotVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding HasFilePath}" Value="False">
                                                <Setter Property="Fill" Value="{StaticResource Brush.Function.Warning}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsDirty}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource Brush.Function.Warning}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>

                            </Ellipse>
                        </Canvas>
                    </Grid>
                </Button>
                <!-- Copy Markdown Button -->
                <Button
                    Margin="0,0,8,0"
                    Command="{Binding CopyMarkdownCommand}"
                    Style="{StaticResource ControlButton}"
                    ui:ToolTipAssist.Text="{i18n:Loc toolbar.copyMarkdown}">
                    <Grid Width="16" Height="16">
                        <Path
                            Data="{StaticResource Icon.Copy}"
                            Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            RenderTransformOrigin="0.5,0.5"
                            Stretch="Uniform">
                            <Path.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Path.RenderTransform>
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Opacity" Value="1" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCopyMarkdownFeedbackVisible}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="Opacity"
                                                            To="0"
                                                            Duration="0:0:0.12" />
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                            To="0.82"
                                                            Duration="0:0:0.16" />
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                            To="0.82"
                                                            Duration="0:0:0.16" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="Opacity"
                                                            To="1"
                                                            Duration="0:0:0.14" />
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                            To="1"
                                                            Duration="0:0:0.16" />
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                            To="1"
                                                            Duration="0:0:0.16" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                        <Path
                            Data="M3.6 8.4 L6.7 11.4 L12.6 4.8"
                            Fill="Transparent"
                            RenderTransformOrigin="0.5,0.5"
                            Stretch="Uniform"
                            Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            StrokeEndLineCap="Round"
                            StrokeLineJoin="Round"
                            StrokeStartLineCap="Round"
                            StrokeThickness="1.8">
                            <Path.RenderTransform>
                                <ScaleTransform ScaleX="0.72" ScaleY="0.72" />
                            </Path.RenderTransform>
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Opacity" Value="0" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCopyMarkdownFeedbackVisible}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="Opacity"
                                                            To="1"
                                                            Duration="0:0:0.16" />
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                            To="1"
                                                            Duration="0:0:0.18" />
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                            To="1"
                                                            Duration="0:0:0.18" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="Opacity"
                                                            To="0"
                                                            Duration="0:0:0.12" />
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                            To="0.72"
                                                            Duration="0:0:0.14" />
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                            To="0.72"
                                                            Duration="0:0:0.14" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Grid>
                </Button>
                <!-- Export File Button -->
                <Button
                    Margin="0,0,8,0"
                    Command="{Binding OpenExportPromptCommand}"
                    Style="{StaticResource ControlButton}"
                    ui:ToolTipAssist.Text="{i18n:Loc export.documentTooltip}">
                    <Path
                        Width="16"
                        Height="16"
                        Data="{StaticResource Icon.Export}"
                        Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Margin="1.5,0,-1.5,0"
                        Stretch="Uniform" />
                </Button>
                <!-- New File Button -->
                <Button
                    Command="{Binding NewFileCommand}"
                    Style="{StaticResource ControlButton}"
                    ui:ToolTipAssist.Text="{i18n:Loc common.new}">
                    <Path
                        Width="16"
                        Height="16"
                        Data="{StaticResource Icon.NewFile}"
                        Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Stretch="Uniform" />
                </Button>
            </StackPanel>

            <!-- Divider -->
            <Border Grid.Column="5" Background="{StaticResource Brush.Background.Hover}" />

            <!-- Settings Button -->
            <Button
                Grid.Column="6"
                Margin="8,0,0,0"
                Command="{Binding OpenSettingsCommand}"
                Style="{StaticResource ControlButton}"
                ui:ToolTipAssist.Text="{i18n:Loc settings.title}">
                <Path
                    Width="16"
                    Height="16"
                    Data="{StaticResource Icon.Settings}"
                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                    Stretch="Uniform" />
            </Button>
        </Grid>
    </Border>
</UserControl>
