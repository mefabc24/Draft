<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Accent Colors -->
    <Color x:Key="Color.Accent.Primary">#A5C8FF</Color>
    <Color x:Key="Color.Accent.PrimaryHover">#8DB9FF</Color>
    <Color x:Key="Color.Accent.Secondary">#79A986</Color>
    <Color x:Key="Color.Accent.Tertiary">#D3A760</Color>

    <!-- Background Colors -->
    <Color x:Key="Color.Background.Window">#0D0D0D</Color>
    <Color x:Key="Color.Background.Surface">#131313</Color>
    <Color x:Key="Color.Background.Secondary">#1B1B1B</Color>
    <Color x:Key="Color.Background.Input">#333538</Color>
    <Color x:Key="Color.Background.InputHover">#222222</Color>
    <Color x:Key="Color.Background.Hover">#1F2020</Color>
    <Color x:Key="Color.Background.SelectedHover">#1F1F1F</Color>
    <Color x:Key="Color.Background.WindowControlClose">#C42B1C</Color>
    <Color x:Key="Color.Background.ScrollbarThumb">#353535</Color>

    <!-- Border Colors -->
    <Color x:Key="Color.Border.Default">#1C1C1C</Color>
    <Color x:Key="Color.Border.Subtle">#1A1A1A</Color>
    <Color x:Key="Color.Border.Input">#43474F</Color>

    <!-- Text and Icon Colors -->
    <Color x:Key="Color.Text.Primary">#E2E2E6</Color>
    <Color x:Key="Color.Text.Secondary">#ACABAA</Color>
    <Color x:Key="Color.Text.Tertiary">#ABABAB</Color>
    <Color x:Key="Color.Text.Muted">#504F4F</Color>
    <Color x:Key="Color.Text.Editor">#D9D9D9</Color>
    <Color x:Key="Color.Text.Inverse">#FFFFFF</Color>
    <Color x:Key="Color.Text.OnAccent">#001C3A</Color>
    <Color x:Key="Color.Icon.Default">#F1F1F1</Color>
    <Color x:Key="Color.Icon.SubtleHover">#A7AFBA</Color>

    <!-- Functional Colors -->
    <Color x:Key="Color.Function.Success">#79A986</Color>
    <Color x:Key="Color.Function.Warning">#D3A760</Color>
    <Color x:Key="Color.Function.Critical">#EF4444</Color>
    <Color x:Key="Color.Function.Info">#60A5FA</Color>
    
    <!-- Utility Colors -->
    <Color x:Key="Color.Shadow.Default">#000000</Color>

    <!-- Accent Brushes -->
    <SolidColorBrush x:Key="Brush.Accent.Primary" Color="{StaticResource Color.Accent.Primary}" />
    <SolidColorBrush x:Key="Brush.Accent.PrimaryHover" Color="{StaticResource Color.Accent.PrimaryHover}" />
    <SolidColorBrush x:Key="Brush.Accent.Secondary" Color="{StaticResource Color.Accent.Secondary}" />

    <!-- Background Brushes -->
    <SolidColorBrush x:Key="Brush.Background.Window" Color="{StaticResource Color.Background.Window}" />
    <SolidColorBrush x:Key="Brush.Background.Surface" Color="{StaticResource Color.Background.Surface}" />
    <SolidColorBrush x:Key="Brush.Background.Secondary" Color="{StaticResource Color.Background.Secondary}" />
    <SolidColorBrush x:Key="Brush.Background.Input" Color="{StaticResource Color.Background.Input}" />
    <SolidColorBrush x:Key="Brush.Background.InputHover" Color="{StaticResource Color.Background.InputHover}" />
    <SolidColorBrush x:Key="Brush.Background.Hover" Color="{StaticResource Color.Background.Hover}" />
    <SolidColorBrush x:Key="Brush.Background.SelectedHover" Color="{StaticResource Color.Background.SelectedHover}" />
    <SolidColorBrush x:Key="Brush.Background.WindowControlClose" Color="{StaticResource Color.Background.WindowControlClose}" />
    <SolidColorBrush x:Key="Brush.Background.ScrollbarThumb" Color="{StaticResource Color.Background.ScrollbarThumb}" />

    <!-- Border Brushes -->
    <SolidColorBrush x:Key="Brush.Border.Default" Color="{StaticResource Color.Border.Default}" />
    <SolidColorBrush x:Key="Brush.Border.Subtle" Color="{StaticResource Color.Border.Subtle}" />
    <SolidColorBrush x:Key="Brush.Border.Input" Color="{StaticResource Color.Border.Input}" />

    <!-- Text and Icon Brushes -->
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{StaticResource Color.Text.Primary}" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Color.Text.Secondary}" />
    <SolidColorBrush x:Key="Brush.Text.Tertiary" Color="{StaticResource Color.Text.Tertiary}" />
    <SolidColorBrush x:Key="Brush.Text.Muted" Color="{StaticResource Color.Text.Muted}" />
    <SolidColorBrush x:Key="Brush.Text.Editor" Color="{StaticResource Color.Text.Editor}" />
    <SolidColorBrush x:Key="Brush.Text.Inverse" Color="{StaticResource Color.Text.Inverse}" />
    <SolidColorBrush x:Key="Brush.Text.OnAccent" Color="{StaticResource Color.Text.OnAccent}" />
    <SolidColorBrush x:Key="Brush.Icon.Default" Color="{StaticResource Color.Icon.Default}" />
    <SolidColorBrush x:Key="Brush.Icon.SubtleHover" Color="{StaticResource Color.Icon.SubtleHover}" />

    <!-- Functional Brushes -->
    <SolidColorBrush x:Key="Brush.Function.Success" Color="{StaticResource Color.Function.Success}" />
    <SolidColorBrush x:Key="Brush.Function.Warning" Color="{StaticResource Color.Function.Warning}" />
    <SolidColorBrush x:Key="Brush.Function.Critical" Color="{StaticResource Color.Function.Critical}" />
    <SolidColorBrush x:Key="Brush.Function.Info" Color="{StaticResource Color.Function.Info}" />

    <!-- Legacy Brushes: keep while usages migrate to semantic names. -->
    <SolidColorBrush x:Key="Brush.PrimaryAccent" Color="{StaticResource Color.Accent.Primary}" />
    <SolidColorBrush x:Key="Brush.SecondaryAccent" Color="{StaticResource Color.Accent.Secondary}" />
    <SolidColorBrush x:Key="Brush.WindowBG" Color="{StaticResource Color.Background.Window}" />
    <SolidColorBrush x:Key="Brush.Island" Color="{StaticResource Color.Background.Surface}" />
    <SolidColorBrush x:Key="Brush.EditorHighlight" Color="{StaticResource Color.Border.Subtle}" />
    <SolidColorBrush x:Key="Brush.Outline" Color="{StaticResource Color.Border.Subtle}" />
    <SolidColorBrush x:Key="Brush.ButtonHover" Color="{StaticResource Color.Background.Hover}" />
    <SolidColorBrush x:Key="Brush.ButtonActive" Color="{StaticResource Color.Background.Hover}" />
    <SolidColorBrush x:Key="Brush.PrimaryText" Color="{StaticResource Color.Text.Tertiary}" />
    <SolidColorBrush x:Key="Brush.MutedText" Color="{StaticResource Color.Text.Muted}" />
    <SolidColorBrush x:Key="Brush.EditorText" Color="{StaticResource Color.Text.Editor}" />
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Function.Success}" />
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Function.Warning}" />
    <SolidColorBrush x:Key="Brush.Critical" Color="{StaticResource Color.Function.Critical}" />
    <SolidColorBrush x:Key="Brush.Info" Color="{StaticResource Color.Function.Info}" />
    <SolidColorBrush x:Key="Brush.WindowControlIcon" Color="{StaticResource Color.Icon.Default}" />
    <SolidColorBrush x:Key="Brush.CloseButtonBackground" Color="{StaticResource Color.Background.WindowControlClose}" />
</ResourceDictionary>
