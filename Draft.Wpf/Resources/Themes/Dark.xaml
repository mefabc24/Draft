<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Accent Colors -->
    <Color x:Key="Color.Accent.Primary">#A5C8FF</Color>
    <Color x:Key="Color.Accent.PrimaryHover">#8DB9FF</Color>
    <Color x:Key="Color.Accent.PrimarySubtle">#1AA5C8FF</Color>
    <Color x:Key="Color.Accent.Secondary">#79A986</Color>
    <Color x:Key="Color.Accent.Tertiary">#D3A760</Color>
    <Color x:Key="Color.Accent.LogoHover">#D2E3FF</Color>

    <!-- Background Colors -->
    <Color x:Key="Color.Background.Window">#0D0D0D</Color>
    <Color x:Key="Color.Background.Surface">#131313</Color>
    <Color x:Key="Color.Background.Secondary">#1B1B1B</Color>
    <Color x:Key="Color.Background.Input">#333538</Color>
    <Color x:Key="Color.Background.InputHover">#222222</Color>
    <Color x:Key="Color.Background.InputSubtleHover">#2E3033</Color>
    <Color x:Key="Color.Background.Hover">#1F2020</Color>
    <Color x:Key="Color.Background.SelectedHover">#1F1F1F</Color>
    <Color x:Key="Color.Background.Popup">#181818</Color>
    <Color x:Key="Color.Background.DialogActions">#0D0D0D</Color>
    <Color x:Key="Color.Background.SecondaryButton">#202020</Color>
    <Color x:Key="Color.Background.SecondaryButtonHover">#282828</Color>
    <Color x:Key="Color.Background.ShortcutRecording">#202020</Color>
    <Color x:Key="Color.Background.Card">#0D0D0D</Color>
    <Color x:Key="Color.Background.CardHover">#101010</Color>
    <Color x:Key="Color.Background.CardSelected">#242528</Color>
    <Color x:Key="Color.Background.CardSelectedHover">#2B2D31</Color>
    <Color x:Key="Color.Background.Toggle">#555555</Color>
    <Color x:Key="Color.Background.ToggleHover">#666666</Color>
    <Color x:Key="Color.Background.ToggleDisabledChecked">#21334B</Color>
    <Color x:Key="Color.Background.ToggleDisabledUnchecked">#161616</Color>
    <Color x:Key="Color.Background.WindowControlHover">#1F2020</Color>
    <Color x:Key="Color.Background.WindowControlClose">#C42B1C</Color>
    <Color x:Key="Color.Background.ScrollbarThumb">#353535</Color>

    <!-- Border Colors -->
    <Color x:Key="Color.Border.Default">#1C1C1C</Color>
    <Color x:Key="Color.Border.Secondary">#1B1B1B</Color>
    <Color x:Key="Color.Border.Subtle">#1A1A1A</Color>
    <Color x:Key="Color.Border.Input">#43474F</Color>
    <Color x:Key="Color.Border.Window">#3D3D3D</Color>
    <Color x:Key="Color.Border.Card">#222222</Color>
    <Color x:Key="Color.Border.MainWindow.Active">#3D3D3D</Color>
    <Color x:Key="Color.Border.MainWindow.Inactive">#3D3D3D</Color>
    <Color x:Key="Color.Border.SettingsWindow.Active">#3D3D3D</Color>
    <Color x:Key="Color.Border.SettingsWindow.Inactive">#3D3D3D</Color>
    <Color x:Key="Color.Border.DialogDivider">#1C1C1C</Color>

    <!-- Text and Icon Colors -->
    <Color x:Key="Color.Text.Primary">#E2E2E6</Color>
    <Color x:Key="Color.Text.Secondary">#ACABAA</Color>
    <Color x:Key="Color.Text.Placeholder">#676767</Color>
    <Color x:Key="Color.Text.Tertiary">#ABABAB</Color>
    <Color x:Key="Color.Text.Muted">#504F4F</Color>
    <Color x:Key="Color.Text.Disabled">#606060</Color>
    <Color x:Key="Color.Text.Editor">#D9D9D9</Color>
    <Color x:Key="Color.Text.Input">#FFFFFF</Color>
    <Color x:Key="Color.Text.Inverse">#FFFFFF</Color>
    <Color x:Key="Color.Text.OnAccent">#001C3A</Color>
    <Color x:Key="Color.Text.OnCritical">#541B1F</Color>
    <Color x:Key="Color.Text.OnWarning">#3A2708</Color>
    <Color x:Key="Color.Text.OnInfo">#0B2A54</Color>
    <Color x:Key="Color.Text.OnSuccess">#0E301A</Color>
    <Color x:Key="Color.Text.OnBadge">#333538</Color>
    <Color x:Key="Color.Icon.Default">#F1F1F1</Color>
    <Color x:Key="Color.Icon.SubtleHover">#A7AFBA</Color>
    <Color x:Key="Color.Icon.WindowControlClose">#F1F1F1</Color>
    <Color x:Key="Color.Control.ToggleThumb">#ACABAA</Color>
    <Color x:Key="Color.Control.ToggleThumbDisabled">#4D4D4D</Color>

    <!-- Functional Colors -->
    <Color x:Key="Color.Function.Success">#79A986</Color>
    <Color x:Key="Color.Function.Warning">#D3A760</Color>
    <Color x:Key="Color.Function.Critical">#E25E5E</Color>
    <Color x:Key="Color.Function.Info">#A5C8FF</Color>

    <!-- Utility Colors -->
    <Color x:Key="Color.Shadow.Default">#000000</Color>
</ResourceDictionary>
