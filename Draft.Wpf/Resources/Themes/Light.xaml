<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Accent Colors -->
    <Color x:Key="Color.Accent.Primary">#0067C0</Color>
    <Color x:Key="Color.Accent.PrimaryHover">#005A9E</Color>
    <Color x:Key="Color.Accent.PrimarySubtle">#1A0067C0</Color>
    <Color x:Key="Color.Accent.Secondary">#107C10</Color>
    <Color x:Key="Color.Accent.Tertiary">#8A5B00</Color>
    <Color x:Key="Color.Accent.LogoHover">#005A9E</Color>

    <!-- Background Colors -->
    <Color x:Key="Color.Background.Window">#F3F3F3</Color>
    <Color x:Key="Color.Background.Surface">#FFFFFF</Color>
    <Color x:Key="Color.Background.Secondary">#F7F7F7</Color>
    <Color x:Key="Color.Background.Input">#F0F0F0</Color>
    <Color x:Key="Color.Background.InputHover">#E8E8E8</Color>
    <Color x:Key="Color.Background.InputSubtleHover">#E4E4E4</Color>
    <Color x:Key="Color.Background.Hover">#E8E8E8</Color>
    <Color x:Key="Color.Background.SelectedHover">#E1E1E1</Color>
    <Color x:Key="Color.Background.Popup">#FFFFFF</Color>
    <Color x:Key="Color.Background.SecondaryButton">#F3F3F3</Color>
    <Color x:Key="Color.Background.SecondaryButtonHover">#E8E8E8</Color>
    <Color x:Key="Color.Background.ShortcutRecording">#FFF4F3</Color>
    <Color x:Key="Color.Background.Card">#FFFFFF</Color>
    <Color x:Key="Color.Background.CardHover">#F7F7F7</Color>
    <Color x:Key="Color.Background.CardSelected">#EAF3FA</Color>
    <Color x:Key="Color.Background.CardSelectedHover">#DDECF7</Color>
    <Color x:Key="Color.Background.Toggle">#8A8A8A</Color>
    <Color x:Key="Color.Background.ToggleDisabledChecked">#B7D4EA</Color>
    <Color x:Key="Color.Background.ToggleDisabledUnchecked">#E2E2E2</Color>
    <Color x:Key="Color.Background.WindowControlClose">#C42B1C</Color>
    <Color x:Key="Color.Background.ScrollbarThumb">#B5B5B5</Color>

    <!-- Border Colors -->
    <Color x:Key="Color.Border.Default">#D6D6D6</Color>
    <Color x:Key="Color.Border.Secondary">#D6D6D6</Color>
    <Color x:Key="Color.Border.Subtle">#E5E5E5</Color>
    <Color x:Key="Color.Border.Input">#B8B8B8</Color>
    <Color x:Key="Color.Border.Window">#C8C8C8</Color>
    <Color x:Key="Color.Border.Card">#D6D6D6</Color>
    <Color x:Key="Color.Border.MainWindow.Active">#C8C8C8</Color>
    <Color x:Key="Color.Border.MainWindow.Inactive">#D6D6D6</Color>
    <Color x:Key="Color.Border.SettingsWindow.Active">#C8C8C8</Color>
    <Color x:Key="Color.Border.SettingsWindow.Inactive">#D6D6D6</Color>

    <!-- Text and Icon Colors -->
    <Color x:Key="Color.Text.Primary">#1F1F1F</Color>
    <Color x:Key="Color.Text.Secondary">#5F5F5F</Color>
    <Color x:Key="Color.Text.Placeholder">#767676</Color>
    <Color x:Key="Color.Text.Tertiary">#5F5F5F</Color>
    <Color x:Key="Color.Text.Muted">#767676</Color>
    <Color x:Key="Color.Text.Disabled">#8A8A8A</Color>
    <Color x:Key="Color.Text.Editor">#1F1F1F</Color>
    <Color x:Key="Color.Text.Input">#1F1F1F</Color>
    <Color x:Key="Color.Text.Inverse">#FFFFFF</Color>
    <Color x:Key="Color.Text.OnAccent">#FFFFFF</Color>
    <Color x:Key="Color.Text.OnCritical">#FFFFFF</Color>
    <Color x:Key="Color.Text.OnWarning">#FFFFFF</Color>
    <Color x:Key="Color.Text.OnInfo">#FFFFFF</Color>
    <Color x:Key="Color.Text.OnSuccess">#FFFFFF</Color>
    <Color x:Key="Color.Text.OnBadge">#FFFFFF</Color>
    <Color x:Key="Color.Icon.Default">#1F1F1F</Color>
    <Color x:Key="Color.Icon.SubtleHover">#5F5F5F</Color>
    <Color x:Key="Color.Icon.WindowControlClose">#FFFFFF</Color>
    <Color x:Key="Color.Control.ToggleThumbDisabled">#A0A0A0</Color>

    <!-- Functional Colors -->
    <Color x:Key="Color.Function.Success">#107C10</Color>
    <Color x:Key="Color.Function.Warning">#8A5B00</Color>
    <Color x:Key="Color.Function.Critical">#C42B1C</Color>
    <Color x:Key="Color.Function.Info">#0067C0</Color>

    <!-- Utility Colors -->
    <Color x:Key="Color.Shadow.Default">#000000</Color>
</ResourceDictionary>
