<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Brushes stay loaded while the active palette is replaced. AppThemeService
        updates these stable brush instances so existing controls change in place.
    -->

    <!-- Accent Brushes -->
    <SolidColorBrush x:Key="Brush.Accent.Primary" Color="{DynamicResource Color.Accent.Primary}" />
    <SolidColorBrush x:Key="Brush.Accent.PrimaryHover" Color="{DynamicResource Color.Accent.PrimaryHover}" />
    <SolidColorBrush x:Key="Brush.Accent.PrimarySubtle" Color="{DynamicResource Color.Accent.PrimarySubtle}" />
    <SolidColorBrush x:Key="Brush.Accent.Secondary" Color="{DynamicResource Color.Accent.Secondary}" />
    <SolidColorBrush x:Key="Brush.Accent.LogoHover" Color="{DynamicResource Color.Accent.LogoHover}" />

    <!-- Background Brushes -->
    <SolidColorBrush x:Key="Brush.Background.Window" Color="{DynamicResource Color.Background.Window}" />
    <SolidColorBrush x:Key="Brush.Background.Surface" Color="{DynamicResource Color.Background.Surface}" />
    <SolidColorBrush x:Key="Brush.Background.Secondary" Color="{DynamicResource Color.Background.Secondary}" />
    <SolidColorBrush x:Key="Brush.Background.Input" Color="{DynamicResource Color.Background.Input}" />
    <SolidColorBrush x:Key="Brush.Background.InputHover" Color="{DynamicResource Color.Background.InputHover}" />
    <SolidColorBrush x:Key="Brush.Background.InputSubtleHover" Color="{DynamicResource Color.Background.InputSubtleHover}" />
    <SolidColorBrush x:Key="Brush.Background.Hover" Color="{DynamicResource Color.Background.Hover}" />
    <SolidColorBrush x:Key="Brush.Background.SelectedHover" Color="{DynamicResource Color.Background.SelectedHover}" />
    <SolidColorBrush x:Key="Brush.Background.Popup" Color="{DynamicResource Color.Background.Popup}" />
    <SolidColorBrush x:Key="Brush.Background.SecondaryButton" Color="{DynamicResource Color.Background.SecondaryButton}" />
    <SolidColorBrush x:Key="Brush.Background.SecondaryButtonHover" Color="{DynamicResource Color.Background.SecondaryButtonHover}" />
    <SolidColorBrush x:Key="Brush.Background.ShortcutRecording" Color="{DynamicResource Color.Background.ShortcutRecording}" />
    <SolidColorBrush x:Key="Brush.Background.Card" Color="{DynamicResource Color.Background.Card}" />
    <SolidColorBrush x:Key="Brush.Background.CardHover" Color="{DynamicResource Color.Background.CardHover}" />
    <SolidColorBrush x:Key="Brush.Background.CardSelected" Color="{DynamicResource Color.Background.CardSelected}" />
    <SolidColorBrush x:Key="Brush.Background.CardSelectedHover" Color="{DynamicResource Color.Background.CardSelectedHover}" />
    <SolidColorBrush x:Key="Brush.Background.Toggle" Color="{DynamicResource Color.Background.Toggle}" />
    <SolidColorBrush x:Key="Brush.Background.ToggleHover" Color="{DynamicResource Color.Background.ToggleHover}" />
    <SolidColorBrush x:Key="Brush.Background.ToggleDisabledChecked" Color="{DynamicResource Color.Background.ToggleDisabledChecked}" />
    <SolidColorBrush x:Key="Brush.Background.ToggleDisabledUnchecked" Color="{DynamicResource Color.Background.ToggleDisabledUnchecked}" />
    <SolidColorBrush x:Key="Brush.Background.WindowControlClose" Color="{DynamicResource Color.Background.WindowControlClose}" />
    <SolidColorBrush x:Key="Brush.Background.ScrollbarThumb" Color="{DynamicResource Color.Background.ScrollbarThumb}" />

    <!-- Border Brushes -->
    <SolidColorBrush x:Key="Brush.Border.Default" Color="{DynamicResource Color.Border.Default}" />
    <SolidColorBrush x:Key="Brush.Border.Secondary" Color="{DynamicResource Color.Border.Secondary}" />
    <SolidColorBrush x:Key="Brush.Border.Subtle" Color="{DynamicResource Color.Border.Subtle}" />
    <SolidColorBrush x:Key="Brush.Border.Input" Color="{DynamicResource Color.Border.Input}" />
    <SolidColorBrush x:Key="Brush.Border.Window" Color="{DynamicResource Color.Border.Window}" />
    <SolidColorBrush x:Key="Brush.Border.Card" Color="{DynamicResource Color.Border.Card}" />
    <SolidColorBrush x:Key="Brush.Border.MainWindow.Active" Color="{DynamicResource Color.Border.MainWindow.Active}" />
    <SolidColorBrush x:Key="Brush.Border.MainWindow.Inactive" Color="{DynamicResource Color.Border.MainWindow.Inactive}" />
    <SolidColorBrush x:Key="Brush.Border.SettingsWindow.Active" Color="{DynamicResource Color.Border.SettingsWindow.Active}" />
    <SolidColorBrush x:Key="Brush.Border.SettingsWindow.Inactive" Color="{DynamicResource Color.Border.SettingsWindow.Inactive}" />
    <SolidColorBrush x:Key="Brush.Border.DialogDivider" Color="{DynamicResource Color.Border.DialogDivider}" />

    <!-- Text and Icon Brushes -->
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{DynamicResource Color.Text.Primary}" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{DynamicResource Color.Text.Secondary}" />
    <SolidColorBrush x:Key="Brush.Text.Placeholder" Color="{DynamicResource Color.Text.Placeholder}" />
    <SolidColorBrush x:Key="Brush.Text.Tertiary" Color="{DynamicResource Color.Text.Tertiary}" />
    <SolidColorBrush x:Key="Brush.Text.Muted" Color="{DynamicResource Color.Text.Muted}" />
    <SolidColorBrush x:Key="Brush.Text.Disabled" Color="{DynamicResource Color.Text.Disabled}" />
    <SolidColorBrush x:Key="Brush.Text.Editor" Color="{DynamicResource Color.Text.Editor}" />
    <SolidColorBrush x:Key="Brush.Text.Input" Color="{DynamicResource Color.Text.Input}" />
    <SolidColorBrush x:Key="Brush.Text.Inverse" Color="{DynamicResource Color.Text.Inverse}" />
    <SolidColorBrush x:Key="Brush.Text.OnAccent" Color="{DynamicResource Color.Text.OnAccent}" />
    <SolidColorBrush x:Key="Brush.Text.OnCritical" Color="{DynamicResource Color.Text.OnCritical}" />
    <SolidColorBrush x:Key="Brush.Text.OnWarning" Color="{DynamicResource Color.Text.OnWarning}" />
    <SolidColorBrush x:Key="Brush.Text.OnInfo" Color="{DynamicResource Color.Text.OnInfo}" />
    <SolidColorBrush x:Key="Brush.Text.OnSuccess" Color="{DynamicResource Color.Text.OnSuccess}" />
    <SolidColorBrush x:Key="Brush.Text.OnBadge" Color="{DynamicResource Color.Text.OnBadge}" />
    <SolidColorBrush x:Key="Brush.Icon.Default" Color="{DynamicResource Color.Icon.Default}" />
    <SolidColorBrush x:Key="Brush.Icon.SubtleHover" Color="{DynamicResource Color.Icon.SubtleHover}" />
    <SolidColorBrush x:Key="Brush.Icon.WindowControlClose" Color="{DynamicResource Color.Icon.WindowControlClose}" />
    <SolidColorBrush x:Key="Brush.Control.ToggleThumb" Color="{DynamicResource Color.Control.ToggleThumb}" />
    <SolidColorBrush x:Key="Brush.Control.ToggleThumbDisabled" Color="{DynamicResource Color.Control.ToggleThumbDisabled}" />

    <!-- Functional Brushes -->
    <SolidColorBrush x:Key="Brush.Function.Success" Color="{DynamicResource Color.Function.Success}" />
    <SolidColorBrush x:Key="Brush.Function.Warning" Color="{DynamicResource Color.Function.Warning}" />
    <SolidColorBrush x:Key="Brush.Function.Critical" Color="{DynamicResource Color.Function.Critical}" />
    <SolidColorBrush x:Key="Brush.Function.Info" Color="{DynamicResource Color.Function.Info}" />

    <!-- Legacy Brushes: keep while usages migrate to semantic names. -->
    <SolidColorBrush x:Key="Brush.PrimaryAccent" Color="{DynamicResource Color.Accent.Primary}" />
    <SolidColorBrush x:Key="Brush.SecondaryAccent" Color="{DynamicResource Color.Accent.Secondary}" />
    <SolidColorBrush x:Key="Brush.WindowBG" Color="{DynamicResource Color.Background.Window}" />
    <SolidColorBrush x:Key="Brush.Island" Color="{DynamicResource Color.Background.Surface}" />
    <SolidColorBrush x:Key="Brush.EditorHighlight" Color="{DynamicResource Color.Border.Subtle}" />
    <SolidColorBrush x:Key="Brush.Outline" Color="{DynamicResource Color.Border.Subtle}" />
    <SolidColorBrush x:Key="Brush.ButtonHover" Color="{DynamicResource Color.Background.Hover}" />
    <SolidColorBrush x:Key="Brush.ButtonActive" Color="{DynamicResource Color.Background.Hover}" />
    <SolidColorBrush x:Key="Brush.PrimaryText" Color="{DynamicResource Color.Text.Tertiary}" />
    <SolidColorBrush x:Key="Brush.MutedText" Color="{DynamicResource Color.Text.Muted}" />
    <SolidColorBrush x:Key="Brush.EditorText" Color="{DynamicResource Color.Text.Editor}" />
    <SolidColorBrush x:Key="Brush.Success" Color="{DynamicResource Color.Function.Success}" />
    <SolidColorBrush x:Key="Brush.Warning" Color="{DynamicResource Color.Function.Warning}" />
    <SolidColorBrush x:Key="Brush.Critical" Color="{DynamicResource Color.Function.Critical}" />
    <SolidColorBrush x:Key="Brush.Info" Color="{DynamicResource Color.Function.Info}" />
    <SolidColorBrush x:Key="Brush.WindowControlIcon" Color="{DynamicResource Color.Icon.Default}" />
    <SolidColorBrush x:Key="Brush.CloseButtonBackground" Color="{DynamicResource Color.Background.WindowControlClose}" />
</ResourceDictionary>
