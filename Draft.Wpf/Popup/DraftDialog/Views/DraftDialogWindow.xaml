<Window
    x:Class="Draft.Dialogs.Views.DraftDialogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dialogs="clr-namespace:Draft.Dialogs.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{Binding Title}"
    Width="478"
    AllowsTransparency="True"
    Background="Transparent"
    Icon="/Assets/Icons/draft.ico"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None"
    mc:Ignorable="d">
    <WindowChrome.WindowChrome>
        <WindowChrome
        CaptionHeight="96"
        GlassFrameThickness="0"
        ResizeBorderThickness="6" />
    </WindowChrome.WindowChrome>
    
    <Border Padding="24" Background="Transparent">
        <Border Padding="16" Style="{StaticResource DraftDialogSurface}">
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Path
                Width="48"
                Height="48"
                HorizontalAlignment="Center"
                Data="{Binding DialogType, Converter={StaticResource DraftDialogIconGeometryConverter}}"
                Stretch="Uniform"
                Stroke="{Binding DialogType, Converter={StaticResource DraftDialogBrushConverter}}"
                StrokeEndLineCap="Round"
                StrokeLineJoin="Round"
                StrokeStartLineCap="Round"
                StrokeThickness="4" />

            <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,24">
                <TextBlock
                    Style="{StaticResource DraftDialogTitleText}"
                    Text="{Binding Title}" Margin="0,0,0,8"/>

                <TextBlock
                    Style="{StaticResource DraftDialogDescriptionText}"
                    Text="{Binding Description}" />
            </StackPanel>


            <ItemsControl
                Grid.Row="2"
                ItemsSource="{Binding Buttons}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <dialogs:DraftDialogButtonPanel Gap="8" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button
                            Height="36"
                            Command="{Binding ClickCommand}"
                            Content="{Binding Text}"
                            Style="{StaticResource DraftDialogActionButton}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </Grid>
        </Border>
    </Border>
</Window>
