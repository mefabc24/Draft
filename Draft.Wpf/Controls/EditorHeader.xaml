<UserControl
    x:Class="Draft.Controls.EditorHeader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Draft.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignWidth="500"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Horizontal">
            <StackPanel Orientation="Horizontal">
                <Path
                    Width="16"
                    Height="16"
                    Margin="0,0,8,0"
                    Data="{StaticResource Icon.File}"
                    Fill="{StaticResource Brush.PrimaryText}"
                    Stretch="Uniform" />
                <TextBlock
                    FontFamily="{StaticResource Font.Manrope}"
                    FontSize="12"
                    FontWeight="Regular"
                    Foreground="{StaticResource Brush.PrimaryText}"
                    Text="lorem_ipsum.md" />
            </StackPanel>


        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal">
            <TextBlock
                Margin="16,0"
                FontFamily="{StaticResource Font.Manrope}"
                FontSize="12"
                FontWeight="Regular"
                Foreground="{StaticResource Brush.PrimaryText}"
                Text="UTF-8" />
            <TextBlock
                FontFamily="{StaticResource Font.Manrope}"
                FontSize="12"
                FontWeight="Regular"
                Foreground="{StaticResource Brush.PrimaryText}"
                Text="Markdown" />
        </StackPanel>
    </Grid>
</UserControl>
