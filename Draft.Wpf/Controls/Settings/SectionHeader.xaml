<UserControl x:Class="Draft.Controls.Settings.SectionHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Draft.Controls.Settings"
             mc:Ignorable="d" >
    <StackPanel >
        <TextBlock Text="HEADER TEXT" FontFamily="{StaticResource Font.Inter}" FontWeight="Medium" FontSize="12" Foreground="{StaticResource Brush.PrimaryAccent}"/>
        <Border Height="1" Background="Red" Margin="0,8,0,32"/>
    </StackPanel>
</UserControl>
