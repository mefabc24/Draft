<UserControl
    x:Class="Draft.Controls.ControlBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Draft.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Border
        Padding="8"
        HorizontalAlignment="Center"
        Background="{StaticResource Brush.Island}"
        BorderBrush="{StaticResource Brush.Outline}"
        BorderThickness="1"
        CornerRadius="8">
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Logo -->
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <!-- Logo -->
            <Button
                Margin="0,0,8,0"
                Content="Draft"
                Style="{StaticResource LogoButton}" />

            <!-- Divider -->
            <Border Grid.Column="1" Background="#1F2020" />

            <!-- Workspace Mode Buttons -->
            <StackPanel
                Grid.Column="2"
                Margin="8,0"
                Orientation="Horizontal">
                <!-- Editor -->
                <RadioButton
                    Content="Editor"
                    GroupName="WorkspaceMode"
                    IsChecked="{Binding IsEditorState, Mode=TwoWay}"
                    Style="{StaticResource ControlRadioButton}" />
                <!-- Split -->
                <RadioButton
                    Margin="8,0"
                    Content="Split"
                    GroupName="WorkspaceMode"
                    IsChecked="{Binding IsSplitState, Mode=TwoWay}"
                    Style="{StaticResource ControlRadioButton}" />
                <!-- Preview -->
                <RadioButton
                    Content="Preview"
                    GroupName="WorkspaceMode"
                    IsChecked="{Binding IsPreviewState, Mode=TwoWay}"
                    Style="{StaticResource ControlRadioButton}" />
            </StackPanel>

            <!-- Divider -->
            <Border Grid.Column="3" Background="#1F2020" />

            <!-- Action Buttons -->
            <StackPanel
                Grid.Column="4"
                Margin="8,0"
                Orientation="Horizontal">
                <!-- Open Button -->
                <Button
                    Command="{Binding OpenFileCommand}"
                    Style="{StaticResource ControlButton}"
                    ToolTip="Open">
                    <Path
                        Width="16"
                        Height="16"
                        Data="{StaticResource Icon.Folder}"
                        Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Stretch="Uniform" />
                </Button>
                <!-- Save Button -->
                <Button
                    Margin="8,0"
                    Command="{Binding SaveFileCommand}"
                    Style="{StaticResource ControlButton}"
                    ToolTip="Save">
                    <Path
                        Width="16"
                        Height="16"
                        Data="{StaticResource Icon.Save}"
                        Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Stretch="Uniform" />
                </Button>
                <!-- New File Button -->
                <Button
                    Command="{Binding NewFileCommand}"
                    Style="{StaticResource ControlButton}"
                    ToolTip="New">
                    <Path
                        Width="16"
                        Height="16"
                        Data="{StaticResource Icon.NewFile}"
                        Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Stretch="Uniform" />
                </Button>
            </StackPanel>

            <!-- Divider -->
            <Border Grid.Column="5" Background="#1F2020" />

            <!-- Settings Button -->
            <Button
                Grid.Column="6"
                Margin="8,0,0,0"
                Command="{Binding OpenSettingsCommand}"
                Style="{StaticResource ControlButton}"
                ToolTip="Settings">
                <Path
                    Width="16"
                    Height="16"
                    Data="{StaticResource Icon.Settings}"
                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                    Stretch="Uniform" />
            </Button>
        </Grid>
    </Border>
</UserControl>
