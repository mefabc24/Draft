<UserControl
    x:Class="Draft.Controls.ControlBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Draft.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Border
        Padding="8"
        HorizontalAlignment="Center"
        Background="{StaticResource Brush.Island}"
        BorderBrush="{StaticResource Brush.Outline}"
        BorderThickness="1"
        CornerRadius="8">
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Logo -->
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <!-- Logo -->
            <Button
                Margin="0,0,8,0"
                Content="Draft"
                Style="{StaticResource LogoButton}" />

            <!-- Divider -->
            <Border Grid.Column="1" Background="{StaticResource Brush.Background.Hover}" />

            <!-- Workspace Mode Buttons -->
            <StackPanel
                Grid.Column="2"
                Margin="8,0"
                Orientation="Horizontal">
                <!-- Editor -->
                <RadioButton
                    Content="Editor"
                    GroupName="WorkspaceMode"
                    IsChecked="{Binding IsEditorState, Mode=TwoWay}"
                    Style="{StaticResource ControlRadioButton}" />
                <!-- Split -->
                <RadioButton
                    Margin="8,0"
                    Content="Split"
                    GroupName="WorkspaceMode"
                    IsChecked="{Binding IsSplitState, Mode=TwoWay}"
                    Style="{StaticResource ControlRadioButton}" />
                <!-- Preview -->
                <RadioButton
                    Content="Preview"
                    GroupName="WorkspaceMode"
                    IsChecked="{Binding IsPreviewState, Mode=TwoWay}"
                    Style="{StaticResource ControlRadioButton}" />
            </StackPanel>

            <!-- Divider -->
            <Border Grid.Column="3" Background="{StaticResource Brush.Background.Hover}" />

            <!-- Action Buttons -->
            <StackPanel
                Grid.Column="4"
                Margin="8,0"
                Orientation="Horizontal">
                <!-- Open Button -->
                <Button
                    Command="{Binding OpenFileCommand}"
                    Style="{StaticResource ControlButton}"
                    ToolTip="Open">
                    <Path
                        Width="16"
                        Height="16"
                        Data="{StaticResource Icon.Folder}"
                        Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Stretch="Uniform" />
                </Button>
                <!-- Save Button -->
                <Button
                    Margin="8,0"
                    Command="{Binding SaveFileCommand}"
                    Style="{StaticResource ControlButton}"
                    ToolTip="Save">
                    <Grid>
                        <Path
                            Width="16"
                            Height="16"
                            Data="{StaticResource Icon.Save}"
                            Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Stretch="Uniform" />
                        <Canvas>
                            <Ellipse
                                Canvas.Top="-5"
                                Canvas.Right="-5"
                                Width="12"
                                Height="12"
                                Fill="{Binding Path=(local:ControlButtonAssist.CutoutBackground), RelativeSource={RelativeSource AncestorType=Button}}">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SaveStatusDotVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <Ellipse
                                Canvas.Top="-4"
                                Canvas.Right="-4"
                                Width="10"
                                Height="10">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource Brush.Function.Success}" />
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SaveStatusDotVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding FileSaveStatusDisplay}" Value="UNSAVED">
                                                <Setter Property="Fill" Value="{StaticResource Brush.Function.Warning}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding FileSaveStatusDisplay}" Value="MODIFIED">
                                                <Setter Property="Fill" Value="{StaticResource Brush.Function.Warning}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>

                            </Ellipse>
                        </Canvas>
                    </Grid>

                </Button>
                <!-- New File Button -->
                <Button
                    Command="{Binding NewFileCommand}"
                    Style="{StaticResource ControlButton}"
                    ToolTip="New">
                    <Path
                        Width="16"
                        Height="16"
                        Data="{StaticResource Icon.NewFile}"
                        Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Stretch="Uniform" />


                </Button>
            </StackPanel>

            <!-- Divider -->
            <Border Grid.Column="5" Background="{StaticResource Brush.Background.Hover}" />

            <!-- Settings Button -->
            <Button
                Grid.Column="6"
                Margin="8,0,0,0"
                Command="{Binding OpenSettingsCommand}"
                Style="{StaticResource ControlButton}"
                ToolTip="Settings">
                <Path
                    Width="16"
                    Height="16"
                    Data="{StaticResource Icon.Settings}"
                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                    Stretch="Uniform" />
            </Button>
        </Grid>
    </Border>
</UserControl>
