<UserControl
    x:Class="Draft.Controls.StatusBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Draft.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="32"
    d:DesignWidth="1000"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="FileSaveStatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Brush.Function.Success}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding FileSaveStatusDisplay}" Value="UNSAVED">
                    <Setter Property="Foreground" Value="{StaticResource Brush.Function.Warning}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding FileSaveStatusDisplay}" Value="MODIFIED">
                    <Setter Property="Foreground" Value="{StaticResource Brush.Function.Warning}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FileSaveStatusPathStyle" TargetType="Path">
            <Setter Property="Fill" Value="{StaticResource Brush.Function.Success}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding FileSaveStatusDisplay}" Value="UNSAVED">
                    <Setter Property="Fill" Value="{StaticResource Brush.Function.Warning}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding FileSaveStatusDisplay}" Value="MODIFIED">
                    <Setter Property="Fill" Value="{StaticResource Brush.Function.Warning}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AutosaveModeTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Brush.Function.Success}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding AutosaveModeDisplay}" Value="MANUAL SAVE">
                    <Setter Property="Foreground" Value="{StaticResource Brush.PrimaryText}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AutosaveModePathStyle" TargetType="Path">
            <Setter Property="Fill" Value="{StaticResource Brush.Function.Success}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding AutosaveModeDisplay}" Value="MANUAL SAVE">
                    <Setter Property="Fill" Value="{StaticResource Brush.PrimaryText}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>

        <!-- Left -->
        <StackPanel Grid.Column="0" Orientation="Horizontal">
            <Button Padding="8,4" Style="{StaticResource StatusBarButton}">
                <StackPanel Height="16" Orientation="Horizontal">
                    <Path
                        Width="16"
                        Height="16"
                        Margin="0,0,8,0"
                        Data="{StaticResource Icon.Markdown}"
                        Fill="{StaticResource Brush.SecondaryAccent}"
                        Stretch="Uniform" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Font.Manrope}"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource Brush.SecondaryAccent}"
                        Text="MARKDOWN" />
                </StackPanel>
            </Button>

            <Button
                Margin="16,0"
                Padding="8,4"
                Style="{StaticResource StatusBarButton}">
                <StackPanel Height="16" Orientation="Horizontal">
                    <Path
                        Width="14"
                        Height="14"
                        Margin="0,0,8,0"
                        Data="{StaticResource Icon.Encoding}"
                        Fill="{StaticResource Brush.PrimaryText}"
                        Stretch="Uniform" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Font.Manrope}"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource Brush.PrimaryText}"
                        Text="UTF-8" />
                </StackPanel>
            </Button>

            <Button
                Margin="0,0,16,0"
                Padding="8,4"
                Style="{StaticResource StatusBarButton}">
                <StackPanel Height="16" Orientation="Horizontal">
                    <Path
                        Width="14"
                        Height="14"
                        Margin="0,0,8,0"
                        Data="{StaticResource Icon.File}"
                        Fill="{StaticResource Brush.PrimaryText}"
                        Stretch="Uniform" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Font.Manrope}"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource Brush.PrimaryText}"
                        Text="{Binding WordCountDisplay, FallbackValue='69 WORDS'}" />
                </StackPanel>
            </Button>

            <Button Padding="8,4" Style="{StaticResource StatusBarButton}">
                <StackPanel Height="16" Orientation="Horizontal">
                    <Path
                        Width="16"
                        Height="16"
                        Margin="0,0,8,0"
                        Data="{StaticResource Icon.Chars}"
                        Fill="{StaticResource Brush.PrimaryText}"
                        Stretch="Uniform" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Font.Manrope}"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource Brush.PrimaryText}"
                        Text="{Binding CharacterCountDisplay, FallbackValue='0 CHARS'}" />
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Right -->
        <StackPanel Grid.Column="2" Orientation="Horizontal">
            <Button
                Command="{Binding OpenCursorPositionPromptCommand}"
                Margin="16,0"
                Padding="8,4"
                Style="{StaticResource StatusBarButton}"
                ToolTip="Go to line or column">
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Font.Manrope}"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource Brush.PrimaryText}"
                    Text="{Binding CursorPositionDisplay, FallbackValue='LN 1, COL 1'}" />
            </Button>

            <Button Padding="8,4" Style="{StaticResource StatusBarButton}">
                <StackPanel Height="16" Orientation="Horizontal">
                    <Path
                        Width="14"
                        Height="14"
                        Margin="0,0,8,0"
                        Data="{StaticResource Icon.Save}"
                        Stretch="Uniform"
                        Style="{StaticResource FileSaveStatusPathStyle}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Font.Manrope}"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Style="{StaticResource FileSaveStatusTextStyle}"
                        Text="{Binding FileSaveStatusDisplay, FallbackValue='UNSAVED'}" />
                </StackPanel>
            </Button>

            <Button Padding="8,4" Style="{StaticResource StatusBarButton}">
                <StackPanel Height="16" Orientation="Horizontal">
                    <Path
                        Width="16"
                        Height="16"
                        Margin="0,0,8,0"
                        Data="{StaticResource Icon.Sync}"
                        Stretch="Uniform"
                        Style="{StaticResource AutosaveModePathStyle}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Font.Manrope}"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Style="{StaticResource AutosaveModeTextStyle}"
                        Text="{Binding AutosaveModeDisplay, FallbackValue='MANUAL SAVE'}" />
                </StackPanel>
            </Button>

        </StackPanel>
    </Grid>
</UserControl>
