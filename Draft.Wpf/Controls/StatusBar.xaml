<UserControl
    x:Class="Draft.Controls.StatusBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Draft.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignWidth="1000"
    mc:Ignorable="d">
    <Grid Margin="0,0,0,1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>

        <!-- Left -->
        <StackPanel Grid.Column="0" Orientation="Horizontal">

            <!-- File Type -->
            <StackPanel Height="16" Orientation="Horizontal" Margin="8,0,32,0">
                <Path
                    Width="16"
                    Height="16"
                    Margin="0,0,8,0"
                    Data="{StaticResource Icon.Markdown}"
                    Fill="{StaticResource Brush.SecondaryAccent}"
                    Stretch="Uniform" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Font.Manrope}"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource Brush.SecondaryAccent}"
                    Text="MARKDOWN" />
            </StackPanel>

            <!-- Encoding Type -->
            <StackPanel Height="16" Orientation="Horizontal">
                <Path
                    Width="14"
                    Height="14"
                    Margin="0,0,8,0"
                    Data="{StaticResource Icon.Encoding}"
                    Fill="{StaticResource Brush.PrimaryText}"
                    Stretch="Uniform" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Font.Manrope}"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource Brush.PrimaryText}"
                    Text="UTF-8" />
            </StackPanel>


            <!-- Word Count -->

            <StackPanel Height="16" Orientation="Horizontal" Margin="32,0">
                <Path
                    Width="14"
                    Height="14"
                    Margin="0,0,8,0"
                    Data="{StaticResource Icon.File}"
                    Fill="{StaticResource Brush.PrimaryText}"
                    Stretch="Uniform" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Font.Manrope}"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource Brush.PrimaryText}"
                    Text="{Binding WordCountDisplay, FallbackValue='69 WORDS'}" />
            </StackPanel>


            <!-- Character Count -->
            <StackPanel Height="16" Orientation="Horizontal">
                <Path
                    Width="16"
                    Height="16"
                    Margin="0,0,8,0"
                    Data="{StaticResource Icon.Chars}"
                    Fill="{StaticResource Brush.PrimaryText}"
                    Stretch="Uniform" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Font.Manrope}"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource Brush.PrimaryText}"
                    Text="{Binding CharacterCountDisplay, FallbackValue='0 CHARS'}" />
            </StackPanel>
        </StackPanel>

        <!-- Right -->

        <!-- Editor Position -->
        <StackPanel Grid.Column="2" Orientation="Horizontal">
            <Button
                Margin="16,0"
                Padding="8,4"
                Command="{Binding OpenCursorPositionPromptCommand}"
                Style="{StaticResource StatusBarButton}"
                ToolTip="Go to line or column">
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Font.Manrope}"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource Brush.PrimaryText}"
                    Text="{Binding CursorPositionDisplay, FallbackValue='LN 1, COL 1'}" />
            </Button>

            <!-- Save Status -->
            <Button
                Padding="8,4"
                Command="{Binding SaveFileCommand}"
                Style="{StaticResource StatusBarButton}"
                ToolTip="Save file">
                <StackPanel Height="16" Orientation="Horizontal">
                    <Path
                        Width="14"
                        Height="14"
                        Margin="0,0,8,0"
                        Data="{StaticResource Icon.Save}"
                        Stretch="Uniform"
                        Style="{StaticResource FileSaveStatusPathStyle}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Font.Manrope}"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Style="{StaticResource FileSaveStatusTextStyle}"
                        Text="{Binding FileSaveStatusDisplay, FallbackValue='UNSAVED'}" />
                </StackPanel>
            </Button>

            <!-- Autosave Status -->
            <Button
                x:Name="AutosaveModeButton"
                Padding="8,4"
                Command="{Binding OpenAutosavePromptCommand}"
                Style="{StaticResource StatusBarButton}">
                <StackPanel Height="16" Orientation="Horizontal">
                    <Path
                        Width="16"
                        Height="16"
                        Margin="0,0,8,0"
                        Data="{StaticResource Icon.Sync}"
                        Stretch="Uniform"
                        Style="{StaticResource AutosaveModePathStyle}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource Font.Manrope}"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Style="{StaticResource AutosaveModeTextStyle}"
                        Text="{Binding AutosaveModeDisplay, FallbackValue='MANUAL SAVE'}" />
                </StackPanel>
            </Button>

        </StackPanel>
    </Grid>
</UserControl>
