<UserControl
    x:Class="Draft.Controls.LoadingDots"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Orientation="Horizontal">
        <StackPanel.Resources>
            <Style TargetType="Ellipse">
                <Setter Property="Width" Value="10" />
                <Setter Property="Height" Value="10" />
                <Setter Property="Margin" Value="5,0" />
                <Setter Property="Fill" Value="{StaticResource Brush.PrimaryAccent}" />
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="0.65" ScaleY="0.65" />
                    </Setter.Value>
                </Setter>
            </Style>
        </StackPanel.Resources>

        <Ellipse x:Name="LoaderDotLeft" />
        <Ellipse x:Name="LoaderDotMiddle" />
        <Ellipse x:Name="LoaderDotRight" />

        <StackPanel.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" Duration="0:0:1.05">
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LoaderDotLeft" Storyboard.TargetProperty="RenderTransform.ScaleX">
                            <SplineDoubleKeyFrame
                                KeySpline="0.45,0 0.55,1"
                                KeyTime="0:0:0.00"
                                Value="1.35" />
                            <SplineDoubleKeyFrame
                                KeySpline="0.45,0 0.55,1"
                                KeyTime="0:0:0.25"
                                Value="0.65" />
                            <SplineDoubleKeyFrame KeyTime="0:0:1.05" Value="0.65" />
                        </DoubleAnimationUsingKeyFrames>
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LoaderDotLeft" Storyboard.TargetProperty="RenderTransform.ScaleY">
                            <SplineDoubleKeyFrame
                                KeySpline="0.45,0 0.55,1"
                                KeyTime="0:0:0.00"
                                Value="1.35" />
                            <SplineDoubleKeyFrame
                                KeySpline="0.45,0 0.55,1"
                                KeyTime="0:0:0.25"
                                Value="0.65" />
                            <SplineDoubleKeyFrame KeyTime="0:0:1.05" Value="0.65" />
                        </DoubleAnimationUsingKeyFrames>

                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LoaderDotMiddle" Storyboard.TargetProperty="RenderTransform.ScaleX">
                            <SplineDoubleKeyFrame KeyTime="0:0:0.00" Value="0.65" />
                            <SplineDoubleKeyFrame
                                KeySpline="0.45,0 0.55,1"
                                KeyTime="0:0:0.15"
                                Value="1.35" />
                            <SplineDoubleKeyFrame
                                KeySpline="0.45,0 0.55,1"
                                KeyTime="0:0:0.40"
                                Value="0.65" />
                            <SplineDoubleKeyFrame KeyTime="0:0:1.05" Value="0.65" />
                        </DoubleAnimationUsingKeyFrames>
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LoaderDotMiddle" Storyboard.TargetProperty="RenderTransform.ScaleY">
                            <SplineDoubleKeyFrame KeyTime="0:0:0.00" Value="0.65" />
                            <SplineDoubleKeyFrame
                                KeySpline="0.45,0 0.55,1"
                                KeyTime="0:0:0.15"
                                Value="1.35" />
                            <SplineDoubleKeyFrame
                                KeySpline="0.45,0 0.55,1"
                                KeyTime="0:0:0.40"
                                Value="0.65" />
                            <SplineDoubleKeyFrame KeyTime="0:0:1.05" Value="0.65" />
                        </DoubleAnimationUsingKeyFrames>

                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LoaderDotRight" Storyboard.TargetProperty="RenderTransform.ScaleX">
                            <SplineDoubleKeyFrame KeyTime="0:0:0.00" Value="0.65" />
                            <SplineDoubleKeyFrame
                                KeySpline="0.45,0 0.55,1"
                                KeyTime="0:0:0.30"
                                Value="1.35" />
                            <SplineDoubleKeyFrame
                                KeySpline="0.45,0 0.55,1"
                                KeyTime="0:0:0.55"
                                Value="0.65" />
                            <SplineDoubleKeyFrame KeyTime="0:0:1.05" Value="0.65" />
                        </DoubleAnimationUsingKeyFrames>
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LoaderDotRight" Storyboard.TargetProperty="RenderTransform.ScaleY">
                            <SplineDoubleKeyFrame KeyTime="0:0:0.00" Value="0.65" />
                            <SplineDoubleKeyFrame
                                KeySpline="0.45,0 0.55,1"
                                KeyTime="0:0:0.30"
                                Value="1.35" />
                            <SplineDoubleKeyFrame
                                KeySpline="0.45,0 0.55,1"
                                KeyTime="0:0:0.55"
                                Value="0.65" />
                            <SplineDoubleKeyFrame KeyTime="0:0:1.05" Value="0.65" />
                        </DoubleAnimationUsingKeyFrames>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </StackPanel.Triggers>
    </StackPanel>
</UserControl>
