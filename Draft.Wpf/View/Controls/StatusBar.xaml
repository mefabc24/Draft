<UserControl
    x:Class="Draft.Controls.StatusBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Draft.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="16"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>

        <!--  Left  -->
        <StackPanel Grid.Column="0" Orientation="Horizontal">
            <StackPanel
                Height="16"
                Margin="0,0,24,0"
                Orientation="Horizontal">
                <Path
                    Width="16"
                    Height="16"
                    Margin="0,0,8,0"
                    Data="{StaticResource Icon.Markdown}"
                    Fill="{StaticResource Brush.SecondaryAccent}"
                    Stretch="Uniform" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Font.Manrope}"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource Brush.SecondaryAccent}"
                    Text="MARKDOWN" />
            </StackPanel>

            <StackPanel Height="16" Orientation="Horizontal">
                <Path
                    Width="16"
                    Height="16"
                    Margin="0,0,8,0"
                    Data="{StaticResource Icon.File}"
                    Fill="{StaticResource Brush.PrimaryText}"
                    Stretch="Uniform" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Font.Manrope}"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource Brush.PrimaryText}"
                    Text="1240 WORDS" />
            </StackPanel>
        </StackPanel>

        <!--  Right  -->
        <StackPanel Grid.Column="2" Orientation="Horizontal">
            <StackPanel Height="16" Orientation="Horizontal">
                <Path
                    Width="16"
                    Height="16"
                    Margin="0,0,8,0"
                    Data="{StaticResource Icons.Sync}"
                    Fill="{StaticResource Brush.PrimaryText}"
                    Stretch="Uniform" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource Font.Manrope}"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource Brush.PrimaryText}"
                    Text="SYNC ACTIVE" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
