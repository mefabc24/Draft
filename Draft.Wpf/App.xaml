<Application
    x:Class="Draft.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Draft">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Foundation/Colors.xaml" />
                <ResourceDictionary Source="/Styles/Foundation/Typography.xaml" />
                <ResourceDictionary Source="/Styles/Foundation/Icons.xaml" />

                <ResourceDictionary Source="/Styles/Components/ControlBarButton.xaml" />
                <ResourceDictionary Source="/Styles/Components/WindowControlButton.xaml" />
                <ResourceDictionary Source="/Styles/Components/SettingsCheckBox.xaml" />
                <ResourceDictionary Source="/Styles/Components/SettingsComboBox.xaml" />
                <ResourceDictionary Source="/Styles/Components/SettingsTextBox.xaml" />
                <ResourceDictionary Source="/Styles/Components/SettingsButtons.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
