<Application
    x:Class="Draft.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Draft">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Foundation/Colors.xaml" />
                <ResourceDictionary Source="/Styles/Foundation/Typography.xaml" />
                <ResourceDictionary Source="/Styles/Foundation/Icons.xaml" />

                <ResourceDictionary Source="/Styles/Components/ControlBarButton.xaml" />
                <ResourceDictionary Source="/Styles/Components/WindowControlButton.xaml" />
                <ResourceDictionary Source="/Styles/Components/StatusBarButton.xaml" />
                <ResourceDictionary Source="/Styles/Components/StatusBarStatus.xaml" />
                <ResourceDictionary Source="/Styles/Components/DraftCloseButton.xaml" />
                <ResourceDictionary Source="/Dialogs/Message/Styles/MessageDialogButtons.xaml" />
                <ResourceDictionary Source="/Styles/Settings/SettingsTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
