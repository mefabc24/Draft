<UserControl
    x:Class="Draft.Dialogs.Prompt.Controls.Prompt"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Draft.Dialogs.Prompt.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:Width="300">
    <Border
        Background="{StaticResource Brush.Background.Input}"
        BorderBrush="{StaticResource Brush.Border.Input}"
        BorderThickness="1"
        CornerRadius="4" Padding="16">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                FontFamily="{StaticResource Font.Manrope}"
                FontSize="14"
                FontWeight="Medium"
                Foreground="{StaticResource Brush.Text.Primary}"
                Text="Enable Autosave" />

            <CheckBox Grid.Column="1" Style="{StaticResource SettingsCheckBox}" IsChecked="False" Background="#555555"/>
        </Grid>
    </Border>
</UserControl>
