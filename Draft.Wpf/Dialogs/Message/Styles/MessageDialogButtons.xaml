<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="clr-namespace:Draft.Dialogs.Message.Models">

    <Style x:Key="MessageDialogButtonBase" TargetType="Button">
        <Setter Property="Height" Value="36" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Manrope}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="ButtonBorder"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.9" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.76" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="MessageDialogPrimaryButton"
        BasedOn="{StaticResource MessageDialogButtonBase}"
        TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Brush.Function.Info}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.OnInfo}" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="{x:Static models:MessageDialogType.Error}">
                <Setter Property="Background" Value="{StaticResource Brush.Function.Critical}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.Text.OnCritical}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="{x:Static models:MessageDialogType.Warning}">
                <Setter Property="Background" Value="{StaticResource Brush.Function.Warning}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.Text.OnWarning}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="{x:Static models:MessageDialogType.Info}">
                <Setter Property="Background" Value="{StaticResource Brush.Function.Info}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.Text.OnInfo}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="{x:Static models:MessageDialogType.Success}">
                <Setter Property="Background" Value="{StaticResource Brush.Function.Success}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.Text.OnSuccess}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="MessageDialogSecondaryButton"
        BasedOn="{StaticResource MessageDialogButtonBase}"
        TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Brush.Background.SecondaryButton}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.Background.SecondaryButtonHover}" />
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
