<UserControl
    x:Class="Draft.Dialogs.Prompts.Autosave.Views.AutosavePromptView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Width="460">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="16">
            <StackPanel>
                <StackPanel HorizontalAlignment="Stretch" Orientation="Vertical">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="40" />
                        </Grid.ColumnDefinitions>
                        <Path
                            Grid.Column="1"
                            Width="48"
                            Height="48"
                            Data="{StaticResource Icon.Dialog.Info}"
                            Stretch="Uniform"
                            Stroke="{StaticResource Brush.Accent.Primary}"
                            StrokeEndLineCap="Round"
                            StrokeLineJoin="Round"
                            StrokeStartLineCap="Round"
                            StrokeThickness="4" />

                        <!-- Close Button -->
                        <Button
                            Grid.Column="2"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource DraftCloseButton}"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                            <Path
                                Width="12"
                                Height="12"
                                Data="{StaticResource Icon.Close}"
                                Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                Stretch="Uniform" />
                        </Button>

                    </Grid>

                    <TextBlock
                        MaxWidth="400"
                        Margin="0,24,0,8"
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Font.Manrope}"
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="Activate Autosave"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />

                    <TextBlock
                        MaxWidth="400"
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource Font.Manrope}"
                        FontSize="16"
                        FontWeight="Regular"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="Choose your preferred saving interval. Confirming activates Autosave."
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Margin="0,16,0,0">
                    <!-- Autosave Toggle Control -->
                    <Border
                        Margin="0,16"
                        Padding="16,24"
                        Background="{StaticResource Brush.Background.Input}"
                        BorderBrush="{StaticResource Brush.Border.Input}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16*" />
                                <ColumnDefinition Width="43*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.ColumnSpan="2"
                                FontFamily="{StaticResource Font.Manrope}"
                                FontSize="14"
                                FontWeight="Medium"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="Enable Autosave" />

                            <CheckBox
                                Grid.Column="2"
                                Background="#555555"
                                IsChecked="{Binding AutosaveEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource SettingsCheckBox}" />
                        </Grid>
                    </Border>

                    <!-- Interval Control -->
                    <ComboBox
                        Height="40"
                        IsEnabled="{Binding IsAutosaveIntervalEnabled}"
                        ItemsSource="{Binding AutosaveIntervalOptions}"
                        SelectedItem="{Binding AutosaveInterval, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource SettingsComboBox}" />
                </StackPanel>
            </StackPanel>
        </Border>


        <Border
            Grid.Row="1"
            Padding="16"
            Background="{StaticResource Brush.Background.Window}"
            BorderBrush="{StaticResource Brush.Border.Default}"
            BorderThickness="0,1,0,0"
            CornerRadius="0,0,8,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Button
                    HorizontalAlignment="Stretch"
                    Command="{Binding CancelCommand}"
                    Content="Abort"
                    Style="{StaticResource MessageDialogSecondaryButton}" />
                <Button
                    Grid.Column="2"
                    HorizontalAlignment="Stretch"
                    Command="{Binding ConfirmCommand}"
                    Content="Confirm"
                    Style="{StaticResource MessageDialogPrimaryButton}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
