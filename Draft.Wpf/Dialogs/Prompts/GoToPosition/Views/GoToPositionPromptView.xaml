<UserControl
    x:Class="Draft.Dialogs.Prompts.GoToPosition.Views.GoToPositionPromptView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i18n="clr-namespace:Draft.Localization"
    xmlns:local="clr-namespace:Draft.Dialogs.Prompts.GoToPosition.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Width="400">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Content -->
        <Border Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        FontFamily="{StaticResource Font.Manrope}"
                        FontSize="28"
                        FontWeight="Bold"
                        Foreground="{StaticResource Brush.Text.Primary}"
                        Text="{i18n:Loc goToPosition.title}" />

                    <!-- Close Button -->
                    <Button
                        Grid.Column="1"
                        VerticalAlignment="Top"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource DraftCloseButton}"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                        <Path
                            Width="12"
                            Height="12"
                            Data="{StaticResource Icon.Close}"
                            Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Stretch="Uniform" />
                    </Button>
                </Grid>

                <StackPanel Grid.Row="1" Margin="0,16,0,0">
                    <TextBlock
                        Margin="0,0,0,8"
                        FontFamily="{StaticResource Font.Inter}"
                        FontSize="12"
                        Foreground="{StaticResource Brush.Text.Secondary}"
                        Text="{i18n:Loc goToPosition.description}" />
                    <TextBox
                        x:Name="PositionTextBox"
                        Height="36"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource SettingsTextBox}"
                        Text="{Binding Input, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock
                        Foreground="{StaticResource Brush.Function.Critical}"
                        Text="{Binding ErrorMessage}"
                        TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasError}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Buttons -->
        <Border
            Grid.Row="1"
            Padding="16"
            Background="{StaticResource Brush.Background.Window}"
            BorderBrush="{StaticResource Brush.Border.Default}"
            BorderThickness="0,1,0,0"
            CornerRadius="0,0,8,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Button
        Padding="24,0"
        VerticalAlignment="Stretch"
        Command="{Binding CancelCommand}"
        Content="{i18n:Loc common.cancel}"
        Style="{StaticResource MessageDialogSecondaryButton}" />
                <Button
        Grid.Column="2"
        Padding="24,0"
        Command="{Binding ConfirmCommand}"
        Content="{i18n:Loc common.confirm}"
        Style="{StaticResource MessageDialogPrimaryButton}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
