<UserControl
    x:Class="Draft.Dialogs.Prompts.RevertSave.Views.RevertSaveView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i18n="clr-namespace:Draft.Localization"
    xmlns:local="clr-namespace:Draft.Dialogs.Prompts.RevertSave.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Width="600">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Content -->
        <Border Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,0,32">
                        <TextBlock
                            FontFamily="{StaticResource Font.Manrope}"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            Text="{i18n:Loc revertSave.title}" />
                        <TextBlock
                            Margin="0,0,0,8"
                            FontFamily="{StaticResource Font.Inter}"
                            FontSize="12"
                            Foreground="{StaticResource Brush.Text.Secondary}"
                            Text="{i18n:Loc revertSave.description}" />

                    </StackPanel>

                    <!-- Close Button -->
                    <Button
                        Grid.Column="1"
                        VerticalAlignment="Top"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource DraftCloseButton}"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                        <Path
                            Width="12"
                            Height="12"
                            Data="{StaticResource Icon.Close}"
                            Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Stretch="Uniform" />
                    </Button>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <RadioButton
                        DataContext="{Binding LastManualSaveCard}"
                        GroupName="SaveOptions"
                        IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        IsEnabled="{Binding IsAvailable}"
                        Style="{StaticResource SaveVersionCard}" />
                    <RadioButton
                        Grid.Column="2"
                        DataContext="{Binding LastAutosaveCard}"
                        GroupName="SaveOptions"
                        IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        IsEnabled="{Binding IsAvailable}"
                        Style="{StaticResource SaveVersionCard}" />
                </Grid>

            </Grid>
        </Border>

        <!-- Buttons -->
        <Border
            Grid.Row="1"
            Padding="16"
            Background="{StaticResource Brush.Background.Window}"
            BorderBrush="{StaticResource Brush.Border.Default}"
            BorderThickness="0,1,0,0"
            CornerRadius="0,0,8,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Button
                    Padding="24,0"
                    VerticalAlignment="Stretch"
                    Command="{Binding CancelCommand}"
                    Content="{i18n:Loc common.cancel}"
                    Style="{StaticResource MessageDialogSecondaryButton}" />
                <Button
                    Grid.Column="2"
                    Padding="24,0"
                    Command="{Binding RestoreSelectionCommand}"
                    Content="{i18n:Loc revertSave.restoreSelection}"
                    IsEnabled="{Binding CanRestoreSelection}"
                    Style="{StaticResource MessageDialogPrimaryButton}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
